@page
@model EduChatbot.RazorPages.Pages.Chat.IndexModel

@{
    Layout = null;
    var subjectName = Model.CurrentSubject?.Name ?? "Chat";
    var subjectCode = Model.CurrentSubject?.Code ?? "";
    var subjectId = Model.CurrentSubject?.Id ?? 0;
    var docCount = Model.Documents?.Count() ?? 0;
    var indexedCount = Model.Documents?.Count(d => d.IsIndexed) ?? 0;
    var processingCount = Model.Documents?.Count(d => !d.IsIndexed && d.IndexStatus != "Failed") ?? 0;
    var messageCount = Model.CurrentSession.Messages?.Count() ?? 0;
    var activeSessionId = Model.ActiveSessionId != 0 ? Model.ActiveSessionId : Model.CurrentSession?.Id ?? 0;
    var activeTab = Model.ActiveTab;
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@subjectName - EduChatbot</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <style>
        * { box-sizing: border-box; }
        body { font-family: 'Inter', sans-serif; background: #0f0f11; color: #e8eaed; overflow: hidden; margin: 0; }
        
        .app { display: flex; height: 100vh; }
        
        /* === SIDEBAR === */
        .sidebar { width: 320px; min-width: 320px; background: #0f0f11; display: flex; flex-direction: column; border-right: 1px solid #1e1e22; }
        
        .sb-header { padding: 16px 20px; border-bottom: 1px solid #1e1e22; display: flex; align-items: center; gap: 12px; }
        .sb-back { width: 34px; height: 34px; border-radius: 8px; background: #1a1a1e; border: 1px solid #2a2a2e; display: flex; align-items: center; justify-content: center; color: #9aa0a6; text-decoration: none; transition: 0.2s; font-size: 0.9rem; }
        .sb-back:hover { background: #2a2a2e; color: #e8eaed; }
        .sb-title { font-weight: 600; font-size: 1rem; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
        .sb-code { font-size: 0.75rem; color: #667eea; font-weight: 500; }
        .subject-nav { border-bottom: 1px solid #1e1e22; padding: 12px 14px; display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 8px; }
        .workspace-tab { color: #9aa0a6; text-decoration: none; border: 1px solid #2a2a2e; background: #1a1a1e; border-radius: 8px; padding: 8px 10px; font-size: 0.76rem; display: inline-flex; align-items: center; justify-content: center; gap: 6px; transition: 0.2s; }
        .workspace-tab:hover { color: #ffffff; border-color: #667eea; background: rgba(102,126,234,0.12); }
        .workspace-tab.active { color: #ffffff; background: #24315a; border-color: #3c4f91; }
        
        .sb-body { flex: 1; overflow-y: auto; padding: 16px 20px; }
        .workspace-summary { border-bottom: 1px solid #1e1e22; color: #9aa0a6; display: flex; flex-wrap: wrap; gap: 6px; margin: 0 0 16px; padding: 0 2px 14px; font-size: 0.73rem; line-height: 1.4; }
        .workspace-summary strong { color: #d4d4d8; font-weight: 600; }
        .workspace-summary .dot { color: #3a3a3e; }
        .workspace-summary .processing { color: #fde293; }
        
        /* Section Title */
        .sec-title { font-size: 0.75rem; font-weight: 600; color: #9aa0a6; text-transform: uppercase; letter-spacing: 0.5px; margin-bottom: 12px; display: flex; align-items: center; gap: 6px; }
        .history-head { display: flex; align-items: center; justify-content: space-between; gap: 8px; margin-bottom: 10px; }
        .history-new { border: 1px solid #2a2a2e; background: #1a1a1e; color: #d4d4d8; border-radius: 8px; width: 30px; height: 30px; display: inline-flex; align-items: center; justify-content: center; transition: 0.2s; }
        .history-new:hover { border-color: #667eea; color: #ffffff; background: rgba(102,126,234,0.12); }
        .history-list { display: grid; gap: 8px; }
        .history-section { border-top: 1px solid #1e1e22; margin-top: 18px; padding-top: 16px; }
        .history-item { display: grid; grid-template-columns: 1fr auto; gap: 8px; align-items: start; background: #1a1a1e; border: 1px solid #2a2a2e; border-radius: 10px; padding: 10px; color: #d4d4d8; text-decoration: none; }
        .history-item:hover { border-color: #3a3a3e; color: #ffffff; }
        .history-item.active { border-color: #667eea; background: rgba(102,126,234,0.1); }
        .history-item a { color: inherit; }
        .history-title { font-size: 0.82rem; font-weight: 600; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
        .history-meta { font-size: 0.68rem; color: #9aa0a6; margin-top: 4px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
        .history-delete { border: 0; background: transparent; color: #5f6368; padding: 2px 4px; border-radius: 6px; line-height: 1; }
        .history-delete:hover { color: #ea4335; background: rgba(234,67,53,0.1); }
        
        /* Upload */
        .upload-area { margin-bottom: 16px; }
        .upload-btn { width: 100%; border: 1px dashed #2a2a2e; border-radius: 12px; padding: 14px; display: flex; align-items: center; justify-content: center; gap: 8px; cursor: pointer; background: transparent; color: #667eea; font-weight: 500; font-size: 0.9rem; transition: 0.2s; }
        .upload-btn:hover { background: rgba(102,126,234,0.05); border-color: #667eea; }
        .upload-progress { display: none; background: #1a1a1e; border: 1px solid #2a2a2e; border-radius: 10px; padding: 12px; margin-top: 10px; }
        .upload-progress.show { display: block; }
        .progress-head { display: flex; justify-content: space-between; gap: 8px; font-size: 0.75rem; color: #d4d4d8; margin-bottom: 8px; }
        .progress-file { overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
        .progress-percent { color: #81c995; font-weight: 600; }
        .progress-track { height: 7px; background: #0f0f11; border-radius: 999px; overflow: hidden; }
        .progress-fill { height: 100%; width: 0%; background: linear-gradient(90deg, #667eea, #81c995); border-radius: 999px; transition: width 0.25s ease; }
        .progress-note { margin-top: 8px; font-size: 0.7rem; color: #9aa0a6; line-height: 1.4; }
        
        /* Source Card */
        .src-card { background: #1a1a1e; border: 1px solid #2a2a2e; border-radius: 10px; padding: 12px; margin-bottom: 8px; display: flex; align-items: flex-start; gap: 10px; transition: 0.2s; }
        .src-card:hover { border-color: #3a3a3e; }
        .src-icon { font-size: 1.5rem; flex-shrink: 0; }
        .src-icon-pdf { color: #ea4335; }
        .src-icon-doc { color: #4285f4; }
        .src-icon-ppt { color: #fbbc04; }
        .src-name { font-size: 0.85rem; font-weight: 500; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
        .src-detail { font-size: 0.7rem; color: #9aa0a6; margin-top: 3px; }
        .badge-ok { background: #1b3a2a; color: #81c995; font-size: 0.65rem; padding: 2px 8px; border-radius: 6px; display: inline-flex; align-items: center; gap: 4px; }
        .badge-wait { background: #3a2e1b; color: #fde293; font-size: 0.65rem; padding: 2px 8px; border-radius: 6px; display: inline-flex; align-items: center; gap: 4px; }
        .badge-fail { background: #3a1b1b; color: #f28b82; font-size: 0.65rem; padding: 2px 8px; border-radius: 6px; display: inline-flex; align-items: center; gap: 4px; }
        .chunk-pill { color: #9aa0a6; font-size: 0.68rem; margin-left: 4px; }
        .del-btn { background: none; border: none; color: #5f6368; padding: 4px; border-radius: 6px; transition: 0.2s; cursor: pointer; }
        .del-btn:hover { color: #ea4335; background: rgba(234,67,53,0.1); }
        .inspect-btn { background: none; border: none; color: #8ea0ff; padding: 4px; border-radius: 6px; transition: 0.2s; cursor: pointer; }
        .inspect-btn:hover { color: #ffffff; background: rgba(102,126,234,0.16); }
        .src-actions { display: flex; align-items: center; gap: 4px; flex-shrink: 0; }
        .inspect-modal { position: fixed; inset: 0; display: none; place-items: center; background: rgba(0,0,0,0.72); z-index: 50; padding: 18px; }
        .inspect-modal.show { display: grid; }
        .inspect-dialog { width: min(1040px, 96vw); max-height: 90vh; overflow: hidden; border: 1px solid #2d2f38; border-radius: 12px; background: #15161a; box-shadow: 0 24px 80px rgba(0,0,0,0.45); }
        .inspect-head { display: flex; align-items: flex-start; justify-content: space-between; gap: 16px; padding: 18px 20px; border-bottom: 1px solid #2a2a2e; }
        .inspect-title { margin: 0; font-size: 1.05rem; font-weight: 800; color: #f5f7fb; display: flex; align-items: center; gap: 8px; }
        .inspect-subtitle { margin-top: 4px; color: #9aa0a6; font-size: .8rem; }
        .inspect-close { border: 0; background: transparent; color: #a4a9b6; font-size: 1.35rem; cursor: pointer; }
        .inspect-body { padding: 14px 18px; overflow-y: auto; max-height: calc(90vh - 82px); }
        .inspect-grid { display: grid; grid-template-columns: minmax(280px, .82fr) minmax(430px, 1.35fr); gap: 14px; align-items: start; }
        .inspect-panel { border: 1px solid #2a2a2e; border-radius: 10px; background: #111216; padding: 14px; }
        .inspect-panel h4 { margin: 0 0 12px; color: #f1f3f4; font-size: .9rem; font-weight: 800; }
        .inspect-kv { display: grid; grid-template-columns: 130px minmax(0, 1fr); gap: 8px 12px; color: #cdd3df; font-size: .78rem; }
        .inspect-kv span:first-child { color: #8f96a7; }
        .pipeline-board { display: grid; gap: 8px; margin-bottom: 12px; }
        .pipeline-phase { border: 1px solid #2a2a2e; border-radius: 10px; background: #111216; padding: 10px 12px; }
        .pipeline-phase h4 { margin: 0 0 8px; color: #f1f3f4; font-size: .82rem; font-weight: 800; display: flex; align-items: center; gap: 7px; }
        .pipeline-strip { display: flex; align-items: center; gap: 6px; flex-wrap: wrap; }
        .flow-chip { border: 1px solid #29304b; border-radius: 999px; background: #1a1f34; color: #dce2f4; padding: 6px 9px; font-size: .7rem; font-weight: 700; display: inline-flex; align-items: center; gap: 6px; }
        .flow-chip span { color: #8ea0ff; font-size: .62rem; text-transform: uppercase; letter-spacing: .04em; }
        .flow-arrow { color: #596177; font-size: .72rem; }
        .answer-flow .flow-chip { background: #151b25; border-color: #263848; }
        .storage-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; }
        .storage-card { margin-top: 10px; padding: 12px; border: 1px solid #292d36; border-radius: 9px; background: #171920; color: #aeb6c5; font-size: .76rem; line-height: 1.5; }
        .storage-card strong { color: #e8ebf2; display: flex; align-items: center; gap: 6px; margin-bottom: 5px; }
        .chunk-list { max-height: 465px; overflow: auto; padding-right: 4px; }
        .chunk-card { border: 1px solid #2a2a2e; border-radius: 10px; background: #101116; margin-bottom: 10px; padding: 13px; }
        .chunk-head { display: flex; justify-content: space-between; gap: 10px; color: #aab2ff; font-size: .76rem; font-weight: 800; margin-bottom: 8px; }
        .chunk-text { color: #d8dde7; font-size: .8rem; line-height: 1.52; max-height: 104px; overflow: auto; white-space: pre-wrap; }
        .vector-preview { margin-top: 10px; display: flex; flex-wrap: wrap; gap: 5px; }
        .vector-pill { border: 1px solid #35405f; border-radius: 999px; padding: 3px 7px; color: #b7c0ff; background: #1d2233; font-size: .68rem; }
        .pipeline-note { margin-top: 8px; color: #8f96a7; font-size: .72rem; line-height: 1.45; }
        @@media (max-width: 860px) { .inspect-grid, .storage-grid { grid-template-columns: 1fr; } }
        
        /* Empty state */
        .empty-hint { text-align: center; padding: 20px 10px; color: #9aa0a6; font-size: 0.85rem; line-height: 1.6; }
        .empty-hint i { font-size: 2rem; color: #667eea40; margin-bottom: 10px; display: block; }
        
        /* === MAIN CHAT === */
        .main { flex: 1; min-width: 0; display: flex; flex-direction: column; background: #141416; border-left: 1px solid #1e1e22; }
        .circuit-panel { width: 430px; min-width: 430px; background: #101114; border-left: 1px solid #1e1e22; display: flex; flex-direction: column; }
        .circuit-head { padding: 14px 16px; border-bottom: 1px solid #1e1e22; display: flex; align-items: center; justify-content: space-between; gap: 10px; }
        .circuit-title { font-weight: 800; color: #f5f7fb; font-size: .9rem; display: flex; align-items: center; gap: 8px; }
        .circuit-actions { display: flex; align-items: center; gap: 8px; }
        .circuit-state { font-size: .68rem; color: #8f96a7; border: 1px solid #2a2a2e; border-radius: 999px; padding: 4px 8px; background: #17181d; white-space: nowrap; }
        .circuit-expand { border: 1px solid #2a2a2e; background: #17181d; color: #c9d1e4; border-radius: 8px; padding: 5px 8px; font-size: .68rem; display: inline-flex; align-items: center; gap: 5px; cursor: pointer; }
        .circuit-expand:hover { border-color: #667eea; color: #ffffff; }
        .circuit-body { padding: 14px; overflow-y: auto; }
        .circuit-summary { display: grid; grid-template-columns: repeat(3, minmax(0, 1fr)); gap: 8px; margin-bottom: 13px; }
        .circuit-summary-card { border: 1px solid #262a35; background: #15161b; border-radius: 10px; padding: 9px; min-width: 0; }
        .circuit-summary-card span { display: block; color: #8f96a7; font-size: .62rem; text-transform: uppercase; letter-spacing: .05em; font-weight: 800; margin-bottom: 4px; }
        .circuit-summary-card strong { display: block; color: #f3f6ff; font-size: .9rem; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
        .circuit-board { position: relative; display: grid; gap: 12px; padding-left: 18px; }
        .circuit-board::before { content: ""; position: absolute; left: 7px; top: 12px; bottom: 14px; width: 2px; background: linear-gradient(180deg, #28543d, #3c4f91 42%, #2a2d38 70%, #28543d); box-shadow: 0 0 18px rgba(102,126,234,.18); }
        .circuit-phase { position: relative; display: flex; align-items: center; gap: 8px; color: #aeb7cf; font-size: .66rem; text-transform: uppercase; letter-spacing: .08em; font-weight: 900; margin-top: 2px; }
        .circuit-phase::before { content: ""; position: absolute; left: -14px; top: 50%; width: 8px; height: 8px; transform: translateY(-50%); border-radius: 999px; background: #667eea; box-shadow: 0 0 14px rgba(102,126,234,.55); }
        .circuit-phase span { border: 1px solid #2a2f42; border-radius: 999px; padding: 4px 7px; background: #141824; color: #dce2ff; }
        .circuit-row { display: grid; gap: 10px; position: relative; }
        .circuit-row.top { grid-template-columns: repeat(3, minmax(0, 1fr)); }
        .circuit-row.branches { grid-template-columns: repeat(3, minmax(0, 1fr)); }
        .circuit-row.merge { grid-template-columns: minmax(0, .95fr) minmax(0, 1.55fr); }
        .circuit-row.final { grid-template-columns: minmax(0, 1fr) minmax(0, 1fr); }
        .circuit-row::before { content: ""; position: absolute; left: -17px; top: 50%; width: 17px; height: 2px; background: #2e3c6d; opacity: .75; }
        .circuit-row.branches::after { content: ""; position: absolute; left: 16%; right: 16%; bottom: -9px; height: 18px; border-left: 1px solid #2e3c6d; border-right: 1px solid #2e3c6d; border-bottom: 1px solid #2e3c6d; border-radius: 0 0 12px 12px; opacity: .65; pointer-events: none; }
        .circuit-lane-note { border: 1px solid #24314a; border-radius: 10px; background: #101722; color: #aeb7cf; font-size: .68rem; padding: 8px 10px; display: flex; align-items: center; gap: 8px; }
        .circuit-lane-note i { color: #8ea2ff; }
        .circuit-node { position: relative; min-width: 0; }
        .circuit-node::before { content: ""; position: absolute; left: -22px; top: 19px; width: 8px; height: 8px; border-radius: 999px; background: #2a2d38; border: 1px solid #4a536a; z-index: 2; }
        .circuit-card { position: relative; border: 1px solid #252833; background: #15161a; border-radius: 10px; padding: 10px; min-height: 82px; overflow: hidden; }
        .circuit-card::before { content: ""; position: absolute; inset: 0 auto 0 0; width: 3px; background: #2b3040; }
        .circuit-icon { width: 26px; height: 26px; border-radius: 8px; display: flex; align-items: center; justify-content: center; background: #191b22; border: 1px solid #2a2d38; color: #737b91; margin-bottom: 8px; }
        .circuit-card h4 { margin: 0 0 5px; color: #e8eaed; font-size: .74rem; font-weight: 800; display: flex; align-items: center; justify-content: space-between; gap: 8px; }
        .circuit-row.branches .circuit-card h4 { align-items: flex-start; flex-direction: column; gap: 4px; }
        .circuit-copy { margin: 0; color: #9aa0a6; font-size: .68rem; line-height: 1.42; }
        .circuit-node.branch .circuit-card { background: #121722; border-color: #26314a; }
        .circuit-wire { height: 12px; position: relative; }
        .circuit-wire::before { content: ""; position: absolute; left: 10%; right: 10%; top: 5px; height: 2px; background: linear-gradient(90deg, transparent, #2e3c6d, transparent); }
        .circuit-node.running .circuit-card { border-color: #3c4f91; box-shadow: 0 0 0 1px rgba(102,126,234,.12); }
        .circuit-node.running .circuit-card::before { background: #667eea; box-shadow: 0 0 14px rgba(102,126,234,.65); }
        .circuit-node.running::before { background: #667eea; box-shadow: 0 0 14px rgba(102,126,234,.75); }
        .circuit-node.running .circuit-icon { color: #ffffff; border-color: #667eea; background: #26315d; }
        .circuit-node.done .circuit-card { border-color: #28543d; }
        .circuit-node.done .circuit-card::before { background: #81c995; }
        .circuit-node.done::before { background: #81c995; border-color: #28543d; box-shadow: 0 0 12px rgba(129,201,149,.42); }
        .circuit-node.done .circuit-icon { color: #81c995; border-color: #28543d; background: #1b3a2a; }
        .circuit-node.blocked .circuit-card, .circuit-node.error .circuit-card { border-color: #5a2828; }
        .circuit-node.blocked .circuit-card::before, .circuit-node.error .circuit-card::before { background: #f28b82; }
        .circuit-node.blocked::before, .circuit-node.error::before { background: #f28b82; border-color: #5a2828; }
        .circuit-node.blocked .circuit-icon, .circuit-node.error .circuit-icon { color: #f28b82; border-color: #5a2828; background: #3a1b1b; }
        .trace-line { display: block; margin-top: 4px; overflow-wrap: anywhere; }
        .trace-line:first-child { margin-top: 0; }
        .trace-line strong { color: #cbd3e6; font-weight: 800; margin-right: 4px; }
        .circuit-chip { color: #aab2ff; font-size: .6rem; text-transform: uppercase; letter-spacing: .05em; font-weight: 800; flex: 0 0 auto; }
        .circuit-kpi { display: flex; gap: 6px; flex-wrap: wrap; margin-top: 8px; }
        .circuit-kpi span { border: 1px solid #2a2f42; border-radius: 999px; padding: 3px 6px; color: #b6bed4; font-size: .62rem; background: #10131a; }
        .circuit-detail { display: none; margin-top: 8px; border-top: 1px solid #242832; padding-top: 8px; }
        .circuit-modal .circuit-detail { display: block; }
        .circuit-panel .evidence-mini .evidence-item:nth-child(n+2) { display: none; }
        .evidence-mini { display: grid; gap: 6px; margin-top: 8px; }
        .evidence-item { border: 1px solid #2a2a2e; border-radius: 8px; padding: 7px; background: #101116; }
        .evidence-item strong { color: #dce2f4; font-size: .68rem; display: block; margin-bottom: 3px; }
        .evidence-item span { color: #9aa0a6; font-size: .66rem; line-height: 1.35; display: block; }
        .circuit-panel.expanded .evidence-item span { font-size: .68rem; }
        .circuit-modal { position: fixed; inset: 0; z-index: 90; background: rgba(0,0,0,.72); backdrop-filter: blur(8px); display: none; align-items: center; justify-content: center; padding: 22px; }
        .circuit-modal.show { display: flex; }
        .circuit-dialog { width: min(1120px, 96vw); max-height: 90vh; overflow: hidden; border: 1px solid #303544; border-radius: 14px; background: #111216; box-shadow: 0 24px 80px rgba(0,0,0,.52); display: flex; flex-direction: column; }
        .circuit-dialog-head { padding: 16px 18px; border-bottom: 1px solid #242832; display: flex; align-items: flex-start; justify-content: space-between; gap: 14px; }
        .circuit-dialog-title { margin: 0; color: #f5f7fb; font-size: 1rem; font-weight: 900; display: flex; align-items: center; gap: 9px; }
        .circuit-dialog-subtitle { color: #9aa0a6; font-size: .76rem; margin-top: 5px; }
        .circuit-dialog-close { border: 0; background: transparent; color: #9aa0a6; font-size: 1.25rem; cursor: pointer; }
        .circuit-dialog-close:hover { color: #fff; }
        .circuit-dialog-body { overflow: auto; padding: 18px; }
        .trace-dashboard { display: grid; gap: 14px; }
        .trace-map-title { display: flex; align-items: center; justify-content: space-between; gap: 12px; border: 1px solid #252833; border-radius: 12px; background: linear-gradient(135deg, #151823, #111216); padding: 12px 14px; }
        .trace-map-title h4 { margin: 0; color: #f5f7fb; font-size: .92rem; display: flex; align-items: center; gap: 8px; }
        .trace-map-title p { margin: 4px 0 0; color: #9aa0a6; font-size: .72rem; }
        .trace-legend { display: flex; flex-wrap: wrap; gap: 8px; padding: 10px; border: 1px solid #252833; border-radius: 12px; background: #15161a; }
        .trace-legend span { display: inline-flex; align-items: center; gap: 6px; color: #aeb6c9; font-size: .7rem; border: 1px solid #2a2f42; border-radius: 999px; padding: 5px 8px; background: #101218; }
        .trace-legend i { width: 8px; height: 8px; border-radius: 999px; display: inline-block; }
        .trace-legend .ok { background: #81c995; }
        .trace-legend .run { background: #667eea; }
        .trace-legend .skip { background: #f28b82; }
        .trace-mini-flow { display: grid; grid-template-columns: repeat(5, minmax(0, 1fr)); gap: 8px; }
        .trace-mini-step { position: relative; border: 1px solid #293044; border-radius: 11px; background: #101218; padding: 10px; min-height: 78px; }
        .trace-mini-step:not(:last-child)::after { content: ""; position: absolute; right: -8px; top: 50%; width: 8px; height: 2px; background: #3c4f91; box-shadow: 0 0 12px rgba(102,126,234,.35); }
        .trace-mini-step strong { display: block; color: #f3f6ff; font-size: .72rem; margin-bottom: 4px; }
        .trace-mini-step span { display: block; color: #9aa0a6; font-size: .66rem; line-height: 1.35; }
        .trace-section-label { color: #8ea2ff; font-size: .7rem; text-transform: uppercase; letter-spacing: .09em; font-weight: 900; margin: 4px 0 -4px; }
        .trace-flow { position: relative; display: grid; gap: 12px; padding-left: 30px; }
        .trace-flow::before { content: ""; position: absolute; left: 12px; top: 18px; bottom: 18px; width: 2px; background: linear-gradient(180deg, #81c995, #667eea 40%, #667eea 62%, #81c995); box-shadow: 0 0 18px rgba(102,126,234,.28); }
        .trace-stage { position: relative; border: 1px solid #252833; background: #15161a; border-radius: 12px; padding: 13px; }
        .trace-stage::before { content: attr(data-step); position: absolute; left: -39px; top: 15px; width: 24px; height: 24px; border-radius: 9px; display: flex; align-items: center; justify-content: center; color: #f4f7ff; font-size: .66rem; font-weight: 900; background: #26315d; border: 1px solid #667eea; box-shadow: 0 0 14px rgba(102,126,234,.35); }
        .trace-stage-head { display: flex; justify-content: space-between; align-items: flex-start; gap: 12px; margin-bottom: 10px; }
        .trace-stage-title { color: #f5f7fb; font-size: .86rem; font-weight: 900; display: flex; align-items: center; gap: 8px; }
        .trace-stage-title small { display: block; color: #8f96a7; font-size: .68rem; font-weight: 600; margin-top: 3px; }
        .trace-stage-status { flex: 0 0 auto; border: 1px solid #28543d; border-radius: 999px; padding: 4px 8px; color: #81c995; background: #102018; font-size: .62rem; font-weight: 900; text-transform: uppercase; letter-spacing: .04em; }
        .trace-stage-status.skip { border-color: #5a2828; color: #f28b82; background: #2a1719; }
        .trace-panel { border: 1px solid #252833; background: #15161a; border-radius: 12px; padding: 14px; }
        .trace-panel h4 { margin: 0 0 10px; font-size: .84rem; color: #f5f7fb; display: flex; align-items: center; gap: 7px; }
        .trace-metrics { display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 8px; }
        .trace-metric { border: 1px solid #282d3b; border-radius: 10px; padding: 9px; background: #101218; }
        .trace-metric span { display: block; color: #8f96a7; font-size: .64rem; text-transform: uppercase; letter-spacing: .05em; font-weight: 800; margin-bottom: 4px; }
        .trace-metric strong { color: #f3f6ff; font-size: .85rem; overflow-wrap: anywhere; }
        .trace-loop { border: 1px solid #26314a; border-radius: 12px; padding: 12px; background: #111722; margin-bottom: 10px; position: relative; }
        .trace-loop-head { display: flex; justify-content: space-between; gap: 10px; color: #dce2f4; font-weight: 900; font-size: .78rem; margin-bottom: 10px; }
        .trace-loop-note { color: #8f96a7; font-size: .68rem; margin: -3px 0 10px; }
        .trace-loop-path { display: grid; grid-template-columns: 1fr auto 1fr; align-items: center; gap: 8px; margin-bottom: 10px; color: #aeb6c9; font-size: .66rem; }
        .trace-loop-path span { border: 1px solid #27304b; border-radius: 999px; padding: 5px 8px; background: #10131a; text-align: center; }
        .trace-loop-path i { color: #667eea; font-size: .85rem; }
        .trace-branches { display: grid; grid-template-columns: repeat(3, minmax(0, 1fr)); gap: 8px; }
        .trace-branch { border: 1px solid #2a2f42; border-radius: 10px; padding: 9px; background: #10131a; min-width: 0; }
        .trace-branch strong { display: flex; justify-content: space-between; gap: 8px; color: #f2f4ff; font-size: .72rem; margin-bottom: 6px; }
        .trace-branch span { display: block; color: #9aa0a6; font-size: .66rem; line-height: 1.4; overflow-wrap: anywhere; }
        .trace-merge-note { margin-top: 8px; border-top: 1px solid #27304b; padding-top: 8px; color: #b8c2dc; font-size: .68rem; display: flex; gap: 8px; flex-wrap: wrap; }
        .trace-evidence-list { display: grid; gap: 8px; }
        .trace-evidence-list .evidence-item span { font-size: .72rem; max-height: none; }
        @@media (max-width: 1100px) { .trace-branches, .trace-metrics, .trace-mini-flow { grid-template-columns: 1fr; } .trace-mini-step:not(:last-child)::after { display: none; } }
        .realtime-toast { position: fixed; right: 18px; bottom: 18px; z-index: 70; max-width: 360px; border: 1px solid #2c3d61; border-radius: 10px; background: #171b28; color: #e8ebf4; box-shadow: 0 18px 55px rgba(0,0,0,.38); padding: 12px 14px; display: none; align-items: flex-start; gap: 10px; font-size: .78rem; line-height: 1.45; }
        .realtime-toast.show { display: flex; }
        .realtime-toast i { color: #85d59d; margin-top: 1px; }
        
        .chat-topbar { padding: 12px 24px; border-bottom: 1px solid #1e1e22; display: flex; justify-content: space-between; align-items: center; }
        .chat-topbar-title { font-weight: 600; font-size: 0.95rem; display: flex; align-items: center; gap: 8px; }
        .chat-topbar-title i { color: #667eea; }
        .scope-badge { font-size: 0.7rem; background: #1b3a2a; color: #81c995; padding: 4px 10px; border-radius: 8px; display: inline-flex; align-items: center; gap: 5px; }
        .topbar-actions { display: flex; align-items: center; gap: 8px; flex-wrap: wrap; justify-content: flex-end; }
        .ai-status { font-size: 0.7rem; border: 1px solid #2a2a2e; background: #1a1a1e; color: #9aa0a6; padding: 4px 10px; border-radius: 8px; display: inline-flex; align-items: center; gap: 6px; }
        .ai-status.ready { background: #1b3a2a; color: #81c995; border-color: #28543d; }
        .ai-status.starting { background: #3a2e1b; color: #fde293; border-color: #5a4521; }
        .ai-status.error { background: #3a1b1b; color: #f28b82; border-color: #5a2828; }
        
        .chat-area { flex: 1; overflow-y: auto; padding: 30px 10%; display: flex; flex-direction: column; scroll-behavior: smooth; }
        .workspace-panel { flex: 1; overflow-y: auto; padding: 34px 8%; }
        .workspace-panel h2 { font-size: 1.45rem; font-weight: 800; margin-bottom: 8px; color: #f5f7fb; }
        .workspace-panel .panel-subtitle { color: #9aa0a6; margin-bottom: 22px; max-width: 760px; line-height: 1.55; }
        .workspace-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(260px, 1fr)); gap: 14px; }
        .workspace-card { background: #1a1a1e; border: 1px solid #2a2a2e; border-radius: 12px; padding: 16px; }
        .workspace-card-title { font-weight: 800; color: #f1f3f4; margin-bottom: 6px; word-break: break-word; }
        .workspace-card-meta { color: #9aa0a6; font-size: 0.82rem; line-height: 1.5; }
        .panel-actions { display: flex; align-items: center; flex-wrap: wrap; gap: 9px; margin-bottom: 18px; }
        .panel-btn { border: 1px solid #303038; background: #1a1a1e; color: #d4d4d8; border-radius: 8px; padding: 8px 11px; text-decoration: none; display: inline-flex; align-items: center; gap: 7px; font-size: 0.82rem; cursor: pointer; }
        .panel-btn:hover { color: #ffffff; border-color: #667eea; background: rgba(102,126,234,0.12); }
        .panel-btn.primary { border-color: #3c4f91; background: #24315a; color: #ffffff; }
        .panel-btn.danger { border-color: #5a2828; background: #2a1719; color: #f28b82; }
        .panel-btn.danger:hover { border-color: #ea4335; background: #3a1b1b; color: #ffffff; }
        .panel-form { display: grid; gap: 14px; max-width: 620px; }
        .panel-label { color: #b9c0cd; font-size: 0.78rem; font-weight: 700; }
        .panel-input { width: 100%; border: 1px solid #303038; background: #101014; color: #f1f3f4; border-radius: 8px; padding: 10px 12px; outline: none; }
        .panel-input:focus { border-color: #667eea; box-shadow: 0 0 0 3px rgba(102,126,234,0.12); }
        .settings-row { display: grid; grid-template-columns: 170px 1fr; gap: 16px; padding: 12px 0; border-bottom: 1px solid #24242a; color: #b9c0cd; }
        .settings-row strong { color: #f1f3f4; }
        
        /* Messages */
        .msg-user { align-self: flex-end; background: #1e2a4a; border: 1px solid #2a3a5a; color: #e8eaed; padding: 14px 18px; border-radius: 16px 16px 4px 16px; margin-bottom: 24px; max-width: 75%; font-size: 0.95rem; line-height: 1.5; }
        
        .msg-bot { align-self: flex-start; margin-bottom: 24px; max-width: 90%; }
        .bot-header { display: flex; align-items: center; gap: 8px; margin-bottom: 8px; }
        .bot-avatar { width: 28px; height: 28px; border-radius: 8px; background: linear-gradient(135deg, #667eea, #764ba2); display: flex; align-items: center; justify-content: center; font-size: 0.8rem; }
        .bot-label { font-size: 0.8rem; font-weight: 600; color: #667eea; }
        .bot-content { font-size: 0.95rem; line-height: 1.7; color: #d4d4d8; }
        .bot-content h3 { font-size: 1rem; color: #f1f3f4; margin: 14px 0 8px; font-weight: 700; }
        .bot-content h3:first-child { margin-top: 0; }
        .bot-content p { margin: 0 0 10px; }
        .bot-content ul, .bot-content ol { margin: 8px 0 12px 1.15rem; padding: 0; }
        .bot-content li { margin: 6px 0; padding-left: 2px; }
        .bot-content strong { color: #ffffff; font-weight: 700; }
        .bot-content .answer-lead { color: #f1f3f4; font-weight: 500; }
        
        /* Citations */
        .sources-used { margin-top: 12px; border: 1px solid #2a2a2e; border-radius: 10px; background: #15161a; overflow: hidden; max-width: 720px; }
        .sources-head { padding: 9px 11px; border-bottom: 1px solid #24262d; color: #dce2f4; font-size: .76rem; font-weight: 800; display: flex; align-items: center; gap: 7px; }
        .sources-list { display: grid; gap: 0; }
        .source-row { padding: 9px 11px; display: grid; gap: 4px; border-bottom: 1px solid #202228; }
        .source-row:last-child { border-bottom: 0; }
        .source-name { color: #f1f3f4; font-size: .76rem; font-weight: 700; display: flex; align-items: center; gap: 6px; }
        .source-meta { color: #9aa0a6; font-size: .68rem; line-height: 1.4; }
        .source-preview { color: #aeb6c5; font-size: .7rem; line-height: 1.35; margin-top: 2px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
        
        /* Welcome */
        .welcome { text-align: center; margin: auto; max-width: 450px; }
        .welcome-icon { width: 64px; height: 64px; border-radius: 16px; background: linear-gradient(135deg, #667eea20, #764ba220); border: 1px solid #667eea30; display: flex; align-items: center; justify-content: center; font-size: 1.8rem; color: #667eea; margin: 0 auto 20px; }
        .welcome h3 { font-weight: 600; margin-bottom: 8px; font-size: 1.3rem; }
        .welcome p { color: #9aa0a6; font-size: 0.9rem; line-height: 1.6; }
        .welcome-tips { margin-top: 24px; text-align: left; }
        .tip { background: #1a1a1e; border: 1px solid #2a2a2e; border-radius: 10px; padding: 12px 16px; margin-bottom: 8px; font-size: 0.85rem; color: #9aa0a6; display: flex; align-items: center; gap: 10px; cursor: pointer; transition: 0.2s; }
        .tip:hover { border-color: #667eea; color: #e8eaed; }
        .tip i { color: #667eea; font-size: 1rem; }
        
        /* Input */
        .input-area { padding: 16px 10% 24px; }
        .input-box { background: #1a1a1e; border: 1px solid #2a2a2e; border-radius: 24px; padding: 6px 6px 6px 20px; display: flex; align-items: center; transition: 0.3s; }
        .input-box:focus-within { border-color: #667eea; box-shadow: 0 0 0 3px rgba(102,126,234,0.1); }
        .input-box input { border: none; background: transparent; color: #e8eaed; flex: 1; outline: none; padding: 10px 0; font-size: 0.95rem; }
        .input-box input::placeholder { color: #5f6368; }
        .send-btn { width: 42px; height: 42px; border-radius: 50%; border: none; background: linear-gradient(135deg, #667eea, #764ba2); color: white; display: flex; align-items: center; justify-content: center; transition: 0.2s; flex-shrink: 0; cursor: pointer; }
        .send-btn:hover { transform: scale(1.05); }
        .send-btn.disabled { background: #2a2a2e; color: #5f6368; pointer-events: none; }
        .send-btn.stop { background: #3a1b1b; color: #f28b82; border: 1px solid #5a2828; }
        .send-btn.stop:hover { background: #4a2020; }
        .input-hint { text-align: center; margin-top: 8px; font-size: 0.7rem; color: #5f6368; }
        
        /* Scrollbar */
        ::-webkit-scrollbar { width: 6px; }
        ::-webkit-scrollbar-track { background: transparent; }
        ::-webkit-scrollbar-thumb { background: #2a2a2e; border-radius: 3px; }
        @@media (max-width: 1180px) {
            .circuit-panel { display: none; }
            .chat-area, .input-area { padding-left: 7%; padding-right: 7%; }
        }
    </style>
</head>
<body>

<div class="app">
    <!-- SIDEBAR -->
    <div class="sidebar">
        <div class="sb-header">
            <a href="/" class="sb-back" title="Back to dashboard"><i class="bi bi-arrow-left"></i></a>
            <div>
                <div class="sb-title">@subjectName</div>
                <div class="sb-code">@subjectCode</div>
            </div>
        </div>
        <nav class="subject-nav" aria-label="Subject workspace navigation">
            <a class="workspace-tab @(activeTab == "chat" ? "active" : "")" asp-page="/Chat/Index" asp-route-subjectId="@subjectId" asp-route-sessionId="@activeSessionId" asp-route-tab="chat"><i class="bi bi-chat-dots"></i> Chat</a>
            @if (Model.CanManageSubject)
            {
                <a class="workspace-tab @(activeTab == "members" ? "active" : "")" asp-page="/Chat/Index" asp-route-subjectId="@subjectId" asp-route-tab="members"><i class="bi bi-people"></i> Members</a>
                <a class="workspace-tab @(activeTab == "settings" ? "active" : "")" asp-page="/Chat/Index" asp-route-subjectId="@subjectId" asp-route-tab="settings"><i class="bi bi-gear"></i> Settings</a>
            }
        </nav>
        
        <div class="sb-body">
            @if (Model.CurrentSession != null)
            {
                <div class="workspace-summary" aria-label="Workspace summary">
                    <span><strong>@indexedCount</strong>/<strong>@docCount</strong> documents indexed</span>
                    @if (processingCount > 0)
                    {
                        <span class="dot">·</span>
                        <span class="processing"><strong>@processingCount</strong> processing</span>
                    }
                    <span class="dot">·</span>
                    <span><strong>@messageCount</strong> messages</span>
                </div>

                @if (activeTab == "chat")
                {
                    @if (Model.CanUploadDocuments)
                    {
                        <div class="sec-title"><i class="bi bi-cloud-arrow-up"></i> Upload documents</div>
                        <div class="upload-area">
                            <form method="post" enctype="multipart/form-data" id="uploadForm" asp-page-handler="Upload" asp-route-subjectId="@subjectId">
                                <input type="hidden" name="subjectId" value="@subjectId" />
                                <input type="hidden" name="sessionId" value="@activeSessionId" />
                                <label class="upload-btn">
                                    <i class="bi bi-plus-lg"></i> Add source (PDF, DOCX, PPTX)
                                    <input type="file" name="file" id="uploadFile" class="d-none" accept=".pdf,.docx,.pptx" />
                                </label>
                            </form>
                            <div class="upload-progress" id="uploadProgress">
                                <div class="progress-head">
                                    <span class="progress-file" id="progressFile">Uploading document...</span>
                                    <span class="progress-percent" id="progressPercent">0%</span>
                                </div>
                                <div class="progress-track"><div class="progress-fill" id="progressFill"></div></div>
                                <div class="progress-note" id="progressNote">Sending file to server.</div>
                            </div>
                        </div>
                    }
                 
                    <!-- Document List -->
                    <div class="sec-title" id="documentList"><i class="bi bi-files"></i> Indexed documents</div>
                 
                    @if (Model.Documents != null && Model.Documents.Any())
                    {
                        foreach (var doc in Model.Documents)
                        {
                            var ext = System.IO.Path.GetExtension(doc.FileName).ToLower();
                            var iconClass = ext == ".pdf" ? "bi-filetype-pdf src-icon-pdf"
                                : ext == ".docx" ? "bi-filetype-docx src-icon-doc"
                                : "bi-filetype-pptx src-icon-ppt";

                            <div class="src-card" data-document-card="@doc.Id">
                                <i class="bi @iconClass src-icon"></i>
                                <div class="flex-grow-1 overflow-hidden">
                                    <div class="src-name" title="@doc.FileName">@doc.FileName</div>
                                    <div class="src-detail">
                                        Uploaded: @doc.UploadedAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm")
                                    </div>
                                    <div class="mt-1">
                                        @if (doc.IsIndexed)
                                        {
                                            <span class="badge-ok"><i class="bi bi-check-circle-fill"></i> Chunked & embedded</span>
                                            <span class="chunk-pill">@doc.ChunkCount chunks</span>
                                        }
                                        else if (doc.IndexStatus == "Failed")
                                        {
                                            <span class="badge-fail" title="@doc.IndexMessage"><i class="bi bi-exclamation-triangle-fill"></i> Index failed</span>
                                        }
                                        else
                                        {
                                            <span class="badge-wait"><i class="bi bi-arrow-repeat"></i> Queued</span>
                                        }
                                    </div>
                                </div>
                                <div class="src-actions">
                                    @if (doc.IsIndexed)
                                    {
                                        <button type="button"
                                                class="inspect-btn"
                                                title="View AI index and answer flow"
                                                data-inspect-document-id="@doc.Id"
                                                data-inspect-file-name="@doc.FileName">
                                            <i class="bi bi-cpu"></i>
                                        </button>
                                    }
                                    @if (Model.CanDeleteDocuments)
                                    {
                                        <form method="post" asp-page-handler="DeleteDocument" asp-route-id="@doc.Id" asp-route-subjectId="@subjectId" asp-route-sessionId="@activeSessionId" onsubmit="return confirmDelete(event, this);">
                                            <button type="submit" class="del-btn" title="Delete"><i class="bi bi-trash3"></i></button>
                                        </form>
                                    }
                                </div>
                            </div>
                        }
                    }
                    else
                    {
                        <div class="empty-hint">
                            <i class="bi bi-inbox"></i>
                            No documents yet.<br/>
                            Upload a file so AI can answer from trusted sources.
                        </div>
                    }

                    <div class="history-section">
                        <div class="history-head">
                            <div class="sec-title mb-0"><i class="bi bi-clock-history"></i> Chat history</div>
                            <form method="post" asp-page-handler="NewSession" asp-route-subjectId="@subjectId">
                                <button type="submit" class="history-new" title="New chat"><i class="bi bi-plus-lg"></i></button>
                            </form>
                        </div>
                        <div class="history-list">
                            @foreach (var session in Model.ChatSessions ?? Enumerable.Empty<ServiceLayer.Models.ChatSessionSummaryDto>())
                            {
                                <div class="history-item @(session.IsActive ? "active" : "")">
                                    <a class="text-decoration-none overflow-hidden" asp-page="/Chat/Index" asp-route-subjectId="@subjectId" asp-route-sessionId="@session.Id" asp-route-tab="chat">
                                        <div class="history-title">@session.Title</div>
                                        <div class="history-meta">@session.MessageCount messages - @session.LastMessagePreview</div>
                                    </a>
                                    <form method="post" asp-page-handler="DeleteSession" asp-route-subjectId="@subjectId" asp-route-sessionId="@session.Id" onsubmit="return confirmDeleteSession(event, this);">
                                        <button type="submit" class="history-delete" title="Delete chat"><i class="bi bi-x-lg"></i></button>
                                    </form>
                                </div>
                            }
                        </div>
                    </div>
                }
            }
        </div>
    </div>
    
    <!-- MAIN CHAT -->
    <div class="main">
        @if (Model.CurrentSession != null)
        {
            @if (activeTab == "chat")
            {
                <div class="chat-topbar">
                    <div class="chat-topbar-title"><i class="bi bi-chat-square-text"></i> Conversation</div>
                    <div class="topbar-actions">
                        <div class="ai-status starting" id="aiStatus"><span class="spinner-border spinner-border-sm"></span> AI is starting</div>
                        @if (processingCount > 0)
                        {
                            <div class="ai-status starting"><span class="spinner-border spinner-border-sm"></span> Indexing @processingCount documents</div>
                        }
                        <div class="scope-badge"><i class="bi bi-shield-lock-fill"></i> Limited to @docCount documents</div>
                    </div>
                </div>
                
                <div class="chat-area" id="chatBox">
                    @if (Model.CurrentSession.Messages == null || !Model.CurrentSession.Messages.Any())
                    {
                        <div class="welcome">
                            <div class="welcome-icon"><i class="bi bi-mortarboard"></i></div>
                            <h3>Start asking questions</h3>
                            <p>Upload documents on the left, then ask naturally. AI answers from indexed content and cites source documents.</p>
                            <div class="welcome-tips">
                                <div class="tip" onclick="fillQ('Summarize the main ideas in this document')"><i class="bi bi-lightbulb"></i> Summarize the main ideas</div>
                                <div class="tip" onclick="fillQ('List the important concepts')"><i class="bi bi-list-task"></i> List important concepts</div>
                                <div class="tip" onclick="fillQ('Explain chapter 1 based on the document')"><i class="bi bi-book"></i> Explain chapter 1</div>
                            </div>
                        </div>
                    }
                    else
                    {
                        foreach (var msg in Model.CurrentSession.Messages.OrderBy(m => m.Timestamp))
                        {
                            if (msg.Role == "User")
                            {
                                <div class="msg-user">@msg.Content</div>
                            }
                            else
                            {
                                <div class="msg-bot">
                                    <div class="bot-header">
                                        <div class="bot-avatar"><i class="bi bi-stars"></i></div>
                                        <span class="bot-label">EduChatbot AI</span>
                                    </div>
                                    <div class="bot-content" data-markdown="@msg.Content"></div>
                                    
                                    @if (!string.IsNullOrEmpty(msg.SourceDocuments))
                                    {
                                        <div class="sources-used">
                                            <div class="sources-head"><i class="bi bi-link-45deg"></i> Sources used</div>
                                            <div class="sources-list">
                                            @foreach (var src in msg.SourceDocuments.Split(",", StringSplitOptions.RemoveEmptyEntries))
                                            {
                                                <div class="source-row">
                                                    <div class="source-name"><i class="bi bi-file-earmark-text"></i> @src.Trim()</div>
                                                    <div class="source-meta">Referenced by this answer</div>
                                                </div>
                                            }
                                            </div>
                                        </div>
                                    }
                                </div>
                            }
                        }
                    }
                </div>

                <div class="input-area">
                    <form method="post" id="chatForm" asp-page-handler="SendMessage" asp-route-subjectId="@subjectId">
                        <input type="hidden" name="subjectId" value="@subjectId" />
                        <input type="hidden" name="sessionId" value="@activeSessionId" />
                        <div class="input-box">
                            <input type="text" name="content" id="chatInput" placeholder="Ask about the indexed documents..." required autocomplete="off" />
                            <button type="submit" class="send-btn" id="sendBtn"><i class="bi bi-arrow-up"></i></button>
                        </div>
                        <div class="input-hint"><i class="bi bi-shield-lock me-1"></i>AI answers from uploaded documents only and attaches source citations automatically.</div>
                    </form>
                </div>
            }
            else if (activeTab == "members" && Model.CanManageSubject)
            {
                <div class="workspace-panel">
                    <h2>Members</h2>
                    <p class="panel-subtitle">Manage who can access @subjectName. Subject leads can add lecturers or students from the same organization; system admins cannot be removed here.</p>
                    @if (Model.AvailableSubjectMembers?.Any() == true)
                    {
                        <form method="post" asp-page-handler="AddMember" asp-route-subjectId="@subjectId" class="panel-actions">
                            <select class="panel-input" name="userId" required style="max-width: 330px;">
                                @foreach (var option in Model.AvailableSubjectMembers)
                                {
                                    <option value="@option.UserId">@option.Email</option>
                                }
                            </select>
                            <input type="hidden" name="roleInSubject" value="auto" />
                            <button type="submit" class="panel-btn primary"><i class="bi bi-person-plus"></i> Add member</button>
                        </form>
                    }
                    else
                    {
                        <div class="empty-hint"><i class="bi bi-person-check"></i>No organization members are available to add.</div>
                    }
                    <div class="workspace-grid">
                        @foreach (var member in Model.SubjectMembers ?? Enumerable.Empty<ServiceLayer.Models.SubjectMembershipAdminDto>())
                        {
                            var subjectRoleLabel = member.RoleInSubject == ServiceLayer.Services.AuthConstants.SubjectLead ? "Subject lead" : member.RoleInSubject;
                            <div class="workspace-card">
                                <div class="workspace-card-title"><i class="bi bi-person-circle me-2 text-primary"></i>@member.UserEmail</div>
                                <div class="workspace-card-meta">Role in subject: @subjectRoleLabel</div>
                                @if (!member.IsCurrentUser && !member.IsSystemAdmin)
                                {
                                    <form method="post" asp-page-handler="RemoveMember" asp-route-subjectId="@subjectId" class="mt-3" onsubmit="return confirm('Remove this member from the subject?');">
                                        <input type="hidden" name="membershipId" value="@member.Id" />
                                        <button type="submit" class="panel-btn danger"><i class="bi bi-person-x"></i> Remove</button>
                                    </form>
                                }
                                else if (member.IsSystemAdmin)
                                {
                                    <div class="workspace-card-meta mt-3"><i class="bi bi-shield-lock me-1"></i>System admin cannot be removed here.</div>
                                }
                            </div>
                        }
                    </div>
                </div>
            }
            else if (activeTab == "settings" && Model.CanManageSubject)
            {
                <div class="workspace-panel">
                    <h2>Settings</h2>
                    <p class="panel-subtitle">Update subject information and review the workspace rules for this subject. Subject deletion is reserved for system admins.</p>
                    <div class="workspace-card">
                        <form method="post" asp-page-handler="UpdateSubject" class="panel-form">
                            <input type="hidden" name="Id" value="@subjectId" />
                            <label>
                                <span class="panel-label">Subject name</span>
                                <input class="panel-input mt-1" type="text" name="Name" value="@subjectName" required />
                            </label>
                            <label>
                                <span class="panel-label">Subject code</span>
                                <input class="panel-input mt-1" type="text" name="Code" value="@subjectCode" required />
                            </label>
                            <div class="panel-actions mb-0">
                                <button type="submit" class="panel-btn primary"><i class="bi bi-check2"></i> Save changes</button>
                            </div>
                        </form>
                        <div class="settings-row mt-3"><strong>Documents</strong><span>@docCount total, @indexedCount indexed, @processingCount processing</span></div>
                        <div class="settings-row"><strong>Chat history</strong><span>@(Model.ChatSessions?.Count ?? 0) sessions for your account in this subject</span></div>
                        <div class="settings-row"><strong>Access rule</strong><span>Only Admin or Subject lead can edit subject settings and manage members. Only Subject lead can upload/delete documents.</span></div>
                        @if (Model.CanDeleteSubject)
                        {
                            <form method="post" asp-page-handler="DeleteSubject" asp-route-subjectId="@subjectId" class="mt-3" onsubmit="return confirm('Delete this subject, its documents, memberships, and chat history?');">
                                <button type="submit" class="panel-btn danger"><i class="bi bi-trash3"></i> Delete subject</button>
                            </form>
                        }
                    </div>
                </div>
            }
        }
    </div>

    @if (activeTab == "chat")
    {
    <aside class="circuit-panel" aria-label="AI processing circuit">
        <div class="circuit-head">
            <div class="circuit-title"><i class="bi bi-cpu"></i> AI Circuit Live</div>
            <div class="circuit-actions">
                <button type="button" class="circuit-expand" id="circuitExpandBtn" title="Open detailed trace"><i class="bi bi-layout-sidebar-inset-reverse"></i> Details</button>
                <div class="circuit-state" id="circuitState">Idle</div>
            </div>
        </div>
        <div class="circuit-body" id="circuitBody">
            <div class="circuit-summary" aria-label="AI trace summary">
                <div class="circuit-summary-card"><span>Intent</span><strong id="circuitIntent">idle</strong></div>
                <div class="circuit-summary-card"><span>Rounds</span><strong id="circuitRounds">0</strong></div>
                <div class="circuit-summary-card"><span>Evidence</span><strong id="circuitEvidenceCount">0 chunks</strong></div>
            </div>
            <div class="circuit-board">
                <div class="circuit-phase"><span>01</span> Gate and query</div>
                <div class="circuit-row top">
                    <div class="circuit-node waiting" data-step="question">
                        <div class="circuit-card"><div class="circuit-icon"><i class="bi bi-chat-dots"></i></div><h4>Question <span class="circuit-chip">waiting</span></h4><div class="circuit-copy">Send a message to watch the RAG pipeline.</div></div>
                    </div>
                    <div class="circuit-node waiting" data-step="scope">
                        <div class="circuit-card"><div class="circuit-icon"><i class="bi bi-shield-check"></i></div><h4>Scope <span class="circuit-chip">waiting</span></h4><div class="circuit-copy">Classifies intent and document scope.</div></div>
                    </div>
                    <div class="circuit-node waiting" data-step="rewrite">
                        <div class="circuit-card"><div class="circuit-icon"><i class="bi bi-pencil-square"></i></div><h4>Rewrite <span class="circuit-chip">waiting</span></h4><div class="circuit-copy">Uses chat context when needed.</div></div>
                    </div>
                </div>
                <div class="circuit-wire"></div>
                <div class="circuit-phase"><span>02</span> Parallel retrieval loop</div>
                <div class="circuit-lane-note"><i class="bi bi-diagram-3"></i> Vector, keyword, and metadata branches run at the same request stage, then merge into one ranked candidate list.</div>
                <div class="circuit-row branches">
                    <div class="circuit-node branch waiting" data-step="vector">
                        <div class="circuit-card"><div class="circuit-icon"><i class="bi bi-bounding-box-circles"></i></div><h4>Vector <span class="circuit-chip">waiting</span></h4><div class="circuit-copy">Embedding query and searching ChromaDB.</div></div>
                    </div>
                    <div class="circuit-node branch waiting" data-step="keyword">
                        <div class="circuit-card"><div class="circuit-icon"><i class="bi bi-type"></i></div><h4>Keyword <span class="circuit-chip">waiting</span></h4><div class="circuit-copy">BM25/token search for exact terms.</div></div>
                    </div>
                    <div class="circuit-node branch waiting" data-step="metadata">
                        <div class="circuit-card"><div class="circuit-icon"><i class="bi bi-tags"></i></div><h4>Metadata <span class="circuit-chip">waiting</span></h4><div class="circuit-copy">File, chapter, variant and duplicate hints.</div></div>
                    </div>
                </div>
                <div class="circuit-wire"></div>
                <div class="circuit-phase"><span>03</span> Evidence and answer</div>
                <div class="circuit-row merge">
                    <div class="circuit-node waiting" data-step="merge">
                        <div class="circuit-card"><div class="circuit-icon"><i class="bi bi-filter-square"></i></div><h4>Rerank/RRF <span class="circuit-chip">waiting</span></h4><div class="circuit-copy">Re-scores retrieved candidates and picks stronger evidence.</div></div>
                    </div>
                    <div class="circuit-node waiting" data-step="evidence">
                        <div class="circuit-card"><div class="circuit-icon"><i class="bi bi-diagram-3"></i></div><h4>Context <span class="circuit-chip">waiting</span></h4><div class="circuit-copy">Only selected chunks are passed into the local LLM.</div></div>
                    </div>
                </div>
                <div class="circuit-wire"></div>
                <div class="circuit-row final">
                    <div class="circuit-node waiting" data-step="llm">
                        <div class="circuit-card"><div class="circuit-icon"><i class="bi bi-stars"></i></div><h4>Local LLM <span class="circuit-chip">waiting</span></h4><div class="circuit-copy">Generates an answer from selected context.</div></div>
                    </div>
                    <div class="circuit-node waiting" data-step="citations">
                        <div class="circuit-card"><div class="circuit-icon"><i class="bi bi-link-45deg"></i></div><h4>Citations <span class="circuit-chip">waiting</span></h4><div class="circuit-copy">Attaches sources used for verification.</div></div>
                    </div>
                </div>
            </div>
        </div>
    </aside>
    }
</div>

<div class="realtime-toast" id="realtimeToast" role="status" aria-live="polite">
    <i class="bi bi-broadcast-pin"></i>
    <span id="realtimeToastText">Workspace updated.</span>
</div>

<div class="circuit-modal" id="circuitTraceModal" aria-hidden="true">
    <div class="circuit-dialog">
        <div class="circuit-dialog-head">
            <div>
                <h3 class="circuit-dialog-title"><i class="bi bi-cpu"></i> AI processing trace</h3>
                <div class="circuit-dialog-subtitle" id="circuitTraceSubtitle">Ask a question to inspect retrieval rounds, evidence, model, and citations.</div>
            </div>
            <button type="button" class="circuit-dialog-close" id="circuitTraceClose" aria-label="Close"><i class="bi bi-x-lg"></i></button>
        </div>
        <div class="circuit-dialog-body" id="circuitTraceBody">
            <div class="empty-hint"><i class="bi bi-cpu"></i>No trace yet. Send a question first.</div>
        </div>
    </div>
</div>

<div class="inspect-modal" id="chunkInspector" aria-hidden="true">
    <div class="inspect-dialog">
        <div class="inspect-head">
            <div>
                <h3 class="inspect-title"><i class="bi bi-cpu"></i> AI index and answer flow</h3>
                <div class="inspect-subtitle" id="inspectorFileName">Document</div>
            </div>
            <button type="button" class="inspect-close" onclick="closeChunkInspector()" aria-label="Close"><i class="bi bi-x-lg"></i></button>
        </div>
        <div class="inspect-body" id="inspectorBody">
            <div class="text-center text-secondary py-4"><span class="spinner-border spinner-border-sm me-2"></span>Loading chunks...</div>
        </div>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/8.0.0/signalr.min.js"></script>
<script>
    window.onload = function() {
        renderExistingBotMessages();
        checkAiStatus();
        setupWorkspaceRealtime();
        var box = document.getElementById("chatBox");
        if (box) {
            box.style.scrollBehavior = 'auto';
            box.scrollTop = box.scrollHeight;
            window.setTimeout(function () { box.style.scrollBehavior = 'smooth'; }, 100);
        }
    };
    function showLoading() {
        document.getElementById('sendBtn').innerHTML = '<span class="spinner-border spinner-border-sm"></span>';
        document.getElementById('sendBtn').classList.add('disabled');
        document.getElementById('chatInput').readOnly = true;
    }
    function fillQ(q) {
        document.getElementById('chatInput').value = q;
        document.getElementById('chatInput').focus();
    }

    function requestToken(form) {
        return form?.querySelector('input[name="__RequestVerificationToken"]')?.value || '';
    }

    const chatForm = document.getElementById('chatForm');
    const chatBox = document.getElementById('chatBox');
    const chatInput = document.getElementById('chatInput');
    const sendBtn = document.getElementById('sendBtn');
    const aiStatus = document.getElementById('aiStatus');
    const circuitState = document.getElementById('circuitState');
    const circuitBody = document.getElementById('circuitBody');
    const circuitPanel = document.querySelector('.circuit-panel');
    const circuitExpandBtn = document.getElementById('circuitExpandBtn');
    const circuitIntent = document.getElementById('circuitIntent');
    const circuitRounds = document.getElementById('circuitRounds');
    const circuitEvidenceCount = document.getElementById('circuitEvidenceCount');
    const circuitTraceModal = document.getElementById('circuitTraceModal');
    const circuitTraceBody = document.getElementById('circuitTraceBody');
    const circuitTraceSubtitle = document.getElementById('circuitTraceSubtitle');
    const circuitTraceClose = document.getElementById('circuitTraceClose');
    let hasIndexedDocs = @((indexedCount > 0).ToString().ToLowerInvariant());
    let uploadInProgress = false;
    let aiReady = false;
    let activeChatController = null;
    let circuitTimers = [];
    let latestCircuitTrace = null;
    let latestCircuitSources = '';
    let latestCircuitQuestion = '';
    const currentSubjectId = @subjectId;
    let realtimeRefreshTimer = null;
    let realtimeToastTimer = null;

    function escapeHtml(value) {
        return String(value || '')
            .replaceAll('&', '&amp;')
            .replaceAll('<', '&lt;')
            .replaceAll('>', '&gt;')
            .replaceAll('"', '&quot;')
            .replaceAll("'", '&#039;');
    }

    function showRealtimeToast(message) {
        const toast = document.getElementById('realtimeToast');
        const toastText = document.getElementById('realtimeToastText');
        if (!toast || !toastText) return;
        toastText.textContent = message;
        toast.classList.add('show');
        window.clearTimeout(realtimeToastTimer);
        realtimeToastTimer = window.setTimeout(() => toast.classList.remove('show'), 3200);
    }

    function scheduleWorkspaceRefresh(message, delay = 900) {
        showRealtimeToast(message);
        window.clearTimeout(realtimeRefreshTimer);
        realtimeRefreshTimer = window.setTimeout(() => window.location.reload(), delay);
    }

    function setupWorkspaceRealtime() {
        if (!window.signalR || !currentSubjectId) return;

        const connection = new signalR.HubConnectionBuilder()
            .withUrl('/hubs/workspace')
            .withAutomaticReconnect()
            .build();

        connection.on('SubjectChanged', event => {
            if (Number(event?.subjectId || 0) !== currentSubjectId) return;

            if (String(event?.action || '') === 'deleted') {
                showRealtimeToast(`${event.subjectName || 'This subject'} was deleted. Returning to dashboard...`);
                window.setTimeout(() => { window.location.href = '/'; }, 850);
                return;
            }

            scheduleWorkspaceRefresh('Subject settings changed. Refreshing workspace...');
        });

        connection.on('DocumentChanged', event => {
            if (Number(event?.subjectId || 0) !== currentSubjectId) return;

            const action = String(event?.action || '');
            if (action === 'deleted' && event?.documentId) {
                document.querySelector(`[data-document-card="${event.documentId}"]`)?.remove();
            }

            const fileLabel = event?.fileName ? `Document ${event.fileName}` : 'Document';
            scheduleWorkspaceRefresh(`${fileLabel} ${action || 'changed'}. Updating workspace...`);
        });

        connection.on('MembershipChanged', event => {
            if (Number(event?.subjectId || 0) !== currentSubjectId) return;
            scheduleWorkspaceRefresh('Subject membership changed. Updating access...');
        });

        connection.start().catch(() => {
            // Realtime updates are optional; normal page actions still work.
        });
    }

    function setAiStatus(state, text) {
        if (!aiStatus) return;
        aiStatus.className = `ai-status ${state}`;
        if (state === 'ready') {
            aiStatus.innerHTML = `<i class="bi bi-check-circle-fill"></i> ${text}`;
        } else if (state === 'error') {
            aiStatus.innerHTML = `<i class="bi bi-exclamation-triangle-fill"></i> ${text}`;
        } else {
            aiStatus.innerHTML = `<span class="spinner-border spinner-border-sm"></span> ${text}`;
        }
    }

    function setChatAvailability(available) {
        aiReady = available;
        const canChat = aiReady && hasIndexedDocs && !uploadInProgress;
        if (!chatInput || !sendBtn) return;
        chatInput.readOnly = !canChat;
        chatInput.placeholder = canChat
            ? 'Ask about the indexed documents...'
            : uploadInProgress
                ? 'The document is being read and embedded. Wait until indexing finishes...'
                : !hasIndexedDocs
                    ? 'No indexed documents are ready yet...'
                    : 'AI Engine is starting. Please wait...';
        sendBtn.classList.toggle('disabled', !canChat);
    }

    async function checkAiStatus(retryCount = 0) {
        setChatAvailability(false);
        setAiStatus('starting', retryCount === 0 ? 'AI is starting' : `Checking AI status (${retryCount + 1})`);

        try {
            const response = await fetch('?handler=AiStatus', { headers: { 'Accept': 'application/json' } });
            const data = await response.json().catch(() => ({}));
            if (response.ok && data.ready) {
                setAiStatus('ready', 'AI san sang');
                setChatAvailability(true);
                return;
            }

            throw new Error(data.message || 'AI Engine chua san sang');
        } catch (error) {
            if (retryCount < 15) {
                window.setTimeout(function () { checkAiStatus(retryCount + 1); }, 2000);
                return;
            }

            setAiStatus('error', 'AI chua ket noi');
            setChatAvailability(false);
        }
    }

    function inlineMarkdown(value) {
        return escapeHtml(value)
            .replace(/\*\*(.+?)\*\*/g, '<strong>$1</strong>')
            .replace(/`(.+?)`/g, '<code>$1</code>');
    }

    function renderMarkdown(value) {
        const lines = String(value || '').replace(/\r\n/g, '\n').split('\n');
        const html = [];
        let listType = null;

        function closeList() {
            if (listType) {
                html.push(`</${listType}>`);
                listType = null;
            }
        }

        for (const rawLine of lines) {
            const line = rawLine.trim();
            if (!line) {
                closeList();
                continue;
            }

            const heading = line.match(/^###\s+(.+)$/);
            if (heading) {
                closeList();
                html.push(`<h3>${inlineMarkdown(heading[1])}</h3>`);
                continue;
            }

            const bullet = line.match(/^[-*]\s+(.+)$/);
            if (bullet) {
                if (listType !== 'ul') {
                    closeList();
                    html.push('<ul>');
                    listType = 'ul';
                }
                html.push(`<li>${inlineMarkdown(bullet[1])}</li>`);
                continue;
            }

            const numbered = line.match(/^\d+[.)]\s+(.+)$/);
            if (numbered) {
                if (listType !== 'ol') {
                    closeList();
                    html.push('<ol>');
                    listType = 'ol';
                }
                html.push(`<li>${inlineMarkdown(numbered[1])}</li>`);
                continue;
            }

            closeList();
            const cls = html.length === 0 ? ' class="answer-lead"' : '';
            html.push(`<p${cls}>${inlineMarkdown(line)}</p>`);
        }

        closeList();
        return html.join('');
    }

    function renderExistingBotMessages() {
        document.querySelectorAll('.bot-content[data-markdown]').forEach(function (node) {
            node.innerHTML = renderMarkdown(node.getAttribute('data-markdown') || '');
        });
    }

    function scrollChatToBottom() {
        if (chatBox) chatBox.scrollTop = chatBox.scrollHeight;
    }

    function clearWelcome() {
        const welcome = chatBox ? chatBox.querySelector('.welcome') : null;
        if (welcome) welcome.remove();
    }

    function appendUserMessage(text) {
        clearWelcome();
        const node = document.createElement('div');
        node.className = 'msg-user';
        node.textContent = text;
        chatBox.appendChild(node);
        scrollChatToBottom();
    }

    function appendBotLoading() {
        const node = document.createElement('div');
        node.className = 'msg-bot';
        node.id = 'botLoadingMessage';
        node.innerHTML = `
            <div class="bot-header">
                <div class="bot-avatar"><i class="bi bi-stars"></i></div>
                <span class="bot-label">EduChatbot AI</span>
            </div>
            <div class="bot-content"><span class="spinner-border spinner-border-sm me-2"></span>Searching indexed documents...</div>`;
        chatBox.appendChild(node);
        scrollChatToBottom();
        return node;
    }

    function splitSources(sourceDocuments) {
        return String(sourceDocuments || '')
            .split(',')
            .map(s => s.trim())
            .filter(Boolean);
    }

    function compactText(value, max = 150) {
        const text = String(value || '').replace(/\s+/g, ' ').trim();
        return text.length > max ? text.slice(0, max - 1) + '…' : text;
    }

    function getProcessingTrace(trace) {
        return trace?.processingTrace || trace?.processing_trace || null;
    }

    function readTraceValue(obj, ...names) {
        for (const name of names) {
            if (obj && Object.prototype.hasOwnProperty.call(obj, name) && obj[name] !== null && obj[name] !== undefined) {
                return obj[name];
            }
        }
        return undefined;
    }

    function yesNo(value) {
        return value ? 'yes' : 'no';
    }

    function asArray(value) {
        return Array.isArray(value) ? value : [];
    }

    function traceLine(label, value) {
        if (value === undefined || value === null || value === '') return '';
        return `<span class="trace-line"><strong>${escapeHtml(label)}:</strong> ${escapeHtml(String(value))}</span>`;
    }

    function circuitContent(summary, detail = '', kpis = []) {
        const chips = (kpis || [])
            .filter(Boolean)
            .map(item => `<span>${escapeHtml(item)}</span>`)
            .join('');
        return `${summary || ''}${chips ? `<div class="circuit-kpi">${chips}</div>` : ''}${detail ? `<div class="circuit-detail">${detail}</div>` : ''}`;
    }

    function traceList(label, values, limit = 3) {
        const list = asArray(values).filter(Boolean).slice(0, limit);
        if (!list.length) return '';
        return traceLine(label, list.join(' | '));
    }

    function traceEvidenceItems(processing, trace) {
        const evidence = asArray(processing?.evidence);
        if (evidence.length) return evidence;
        return Array.isArray(trace?.contexts) ? trace.contexts : [];
    }

    function sourceNamesFromEvidence(contexts) {
        const names = new Set();
        contexts.forEach(ctx => {
            const source = ctx?.source;
            if (source) names.add(source);
        });
        return names;
    }

    function renderSources(sourceDocuments, trace) {
        const processing = getProcessingTrace(trace);
        const intent = processing?.intent || '';
        const traceCitations = asArray(processing?.citations);
        const contexts = traceEvidenceItems(processing, trace);
        const sourceNames = contexts.length ? sourceNamesFromEvidence(contexts) : new Set(splitSources(sourceDocuments));
        if (!contexts.length) {
            traceCitations.forEach(source => {
                if (source) sourceNames.add(source);
            });
        }

        if (!sourceNames.size || ['greeting', 'small_talk', 'non_document_question', 'arithmetic', 'out_of_scope', 'system', 'ambiguous_acronym'].includes(intent)) return '';

        const rows = Array.from(sourceNames).map(source => {
            const related = contexts.filter(ctx => ctx?.source === source);
            const first = related[0] || {};
            const bits = [];
            const chapters = Array.from(new Set(related.map(ctx => readTraceValue(ctx, 'chapterNumber', 'chapter_number')).filter(Boolean)));
            const pages = Array.from(new Set(related.map(ctx => readTraceValue(ctx, 'pageNumber', 'page_number')).filter(Boolean)));
            const section = readTraceValue(first, 'sectionPath', 'section_path');
            const variant = readTraceValue(first, 'sourceVariant', 'source_variant');
            if (chapters.length) bits.push(`chapter ${chapters.slice(0, 2).join(', ')}`);
            if (pages.length) bits.push(`page ${pages.slice(0, 3).join(', ')}`);
            if (section) bits.push(compactText(section, 70));
            if (variant) bits.push(variant);
            const meta = related.length
                ? `${related.length} evidence chunk${related.length > 1 ? 's' : ''}${bits.length ? ' · ' + bits.join(' · ') : ''}`
                : 'Referenced by this answer';
            const previewText = readTraceValue(first, 'content', 'preview');
            const preview = previewText ? `<div class="source-preview" title="${escapeHtml(compactText(previewText, 260))}">${escapeHtml(compactText(previewText, 95))}</div>` : '';
            return `<div class="source-row">
                <div class="source-name"><i class="bi bi-file-earmark-text"></i> ${escapeHtml(source)}</div>
                <div class="source-meta">${escapeHtml(meta)}</div>
                ${preview}
            </div>`;
        }).join('');

        return `<div class="sources-used">
            <div class="sources-head"><i class="bi bi-link-45deg"></i> Sources used</div>
            <div class="sources-list">${rows}</div>
        </div>`;
    }

    function setBotMessage(node, text, sourceDocuments, trace) {
        node.innerHTML = `
            <div class="bot-header">
                <div class="bot-avatar"><i class="bi bi-stars"></i></div>
                <span class="bot-label">EduChatbot AI</span>
            </div>
            <div class="bot-content">${renderMarkdown(text)}</div>
            ${renderSources(sourceDocuments, trace)}`;
        scrollChatToBottom();
    }

    function setSending(isSending) {
        sendBtn.innerHTML = isSending
            ? '<i class="bi bi-stop-fill"></i>'
            : '<i class="bi bi-arrow-up"></i>';
        sendBtn.classList.toggle('stop', isSending);
        sendBtn.classList.toggle('disabled', false);
        chatInput.readOnly = isSending;
    }

    function clearCircuitTimers() {
        circuitTimers.forEach(timer => window.clearTimeout(timer));
        circuitTimers = [];
    }

    function circuitNodes() {
        return circuitBody ? Array.from(circuitBody.querySelectorAll('.circuit-node')) : [];
    }

    function setCircuitState(text) {
        if (circuitState) circuitState.textContent = text;
    }

    function setCircuitSummary(intent = 'idle', rounds = 0, evidenceCount = 0) {
        if (circuitIntent) circuitIntent.textContent = compactText(intent || 'idle', 18);
        if (circuitRounds) circuitRounds.textContent = `${rounds || 0} loop${Number(rounds || 0) === 1 ? '' : 's'}`;
        if (circuitEvidenceCount) circuitEvidenceCount.textContent = `${evidenceCount || 0} chunk${Number(evidenceCount || 0) === 1 ? '' : 's'}`;
    }

    function updateCircuitStep(step, status, detail, chip) {
        const node = circuitBody?.querySelector(`[data-step="${step}"]`);
        if (!node) return;
        node.classList.remove('waiting', 'running', 'done', 'blocked', 'error');
        node.classList.add(status);
        const label = node.querySelector('.circuit-chip');
        const body = node.querySelector('.circuit-copy');
        if (label) label.textContent = chip || status;
        if (body) body.innerHTML = detail || body.innerHTML;
    }

    if (circuitExpandBtn) {
        circuitExpandBtn.addEventListener('click', function () {
            openCircuitTraceModal();
        });
    }

    if (circuitTraceClose) {
        circuitTraceClose.addEventListener('click', closeCircuitTraceModal);
    }

    if (circuitTraceModal) {
        circuitTraceModal.addEventListener('click', function (event) {
            if (event.target === circuitTraceModal) closeCircuitTraceModal();
        });
    }

    function resetCircuit() {
        clearCircuitTimers();
        setCircuitState('Idle');
        setCircuitSummary('idle', 0, 0);
        latestCircuitTrace = null;
        latestCircuitSources = '';
        circuitNodes().forEach(node => {
            node.classList.remove('running', 'done', 'blocked', 'error');
            node.classList.add('waiting');
            const chip = node.querySelector('.circuit-chip');
            if (chip) chip.textContent = 'waiting';
        });
        updateCircuitStep('question', 'waiting', 'Send a message to watch the RAG pipeline.', 'waiting');
        updateCircuitStep('scope', 'waiting', 'Classifies intent and document scope.', 'waiting');
        updateCircuitStep('rewrite', 'waiting', 'Uses chat context when needed.', 'waiting');
        updateCircuitStep('vector', 'waiting', 'Embedding query and searching ChromaDB.', 'waiting');
        updateCircuitStep('keyword', 'waiting', 'BM25/token search for exact terms.', 'waiting');
        updateCircuitStep('metadata', 'waiting', 'File, chapter, variant and duplicate hints.', 'waiting');
        updateCircuitStep('merge', 'waiting', 'Reranks retrieved candidates with RRF/scoring.', 'waiting');
        updateCircuitStep('evidence', 'waiting', 'Builds the final context window from selected chunks.', 'waiting');
        updateCircuitStep('llm', 'waiting', 'Generates an answer from selected context.', 'waiting');
        updateCircuitStep('citations', 'waiting', 'Attaches sources used for verification.', 'waiting');
    }

    function isGreeting(message) {
        return /^(hi|hello|helo|xin chào|chào|chao|bạn là ai|ban la ai)$/i.test(message.trim());
    }

    function likelyOutOfScope(message) {
        return /^(1\s*\+\s*1|hôm nay|hom nay|thời tiết|thoi tiet|mấy giờ|may gio)/i.test(message.trim());
    }

    function likelySmallTalk(message) {
        return /^(tao đẹp trai|toi dep trai|tôi đẹp trai|mình đẹp trai|minh dep trai|tao xinh|tôi xinh|toi buon|tôi buồn|tao buồn|chán quá|chan qua|ok|oke|haha|hihi|hehe|lol)$/i.test(message.trim());
    }

    function likelyDocumentQuestion(message) {
        const text = String(message || '').toLowerCase().normalize('NFD').replace(/[\u0300-\u036f]/g, '');
        const docTerms = /(tai lieu|file|pdf|sach|book|document|source|nguon|chuong|chapter|section|muc|phan|trang|page|gomaa|ddia|uml|database|normalization|use case|class diagram|reliability|scalability|software|design)/i;
        const learningTerms = /(tom tat|summary|summarize|y chinh|main idea|noi dung|noi ve|noi gi|giai thich|explain|so sanh|compare|liet ke|list|khac nhau|giong nhau|mau thuan|nghia la gi|la gi|what is|how many)/i;
        if (docTerms.test(text) || learningTerms.test(text)) return true;
        if (text.includes('?') && text.trim().split(/\s+/).length >= 4 && !/(toi|tao|minh|ban|dep|xau|buon|vui|yeu|ghet)/i.test(text)) return true;
        return false;
    }

    function startCircuit(message) {
        resetCircuit();
        latestCircuitQuestion = message;
        setCircuitSummary('running', 1, 0);
        setCircuitState('Running');
        updateCircuitStep('question', 'done', circuitContent(escapeHtml(compactText(message, 120))), 'received');

        const likelyGateBlocked = !isGreeting(message) && (likelyOutOfScope(message) || likelySmallTalk(message) || !likelyDocumentQuestion(message));
        const scopeText = isGreeting(message)
            ? 'Greeting detected. Retrieval may be skipped.'
            : likelyGateBlocked
                ? 'Not a document-learning question. Retrieval should be skipped.'
                : 'Document-learning question. Continue with RAG.';

        circuitTimers.push(window.setTimeout(() => updateCircuitStep('scope', likelyGateBlocked ? 'blocked' : 'done', circuitContent(scopeText), likelyGateBlocked ? 'blocked' : 'checked'), 250));
        circuitTimers.push(window.setTimeout(() => updateCircuitStep('rewrite', likelyGateBlocked ? 'blocked' : 'running', circuitContent(likelyGateBlocked ? 'No rewrite needed because retrieval is blocked.' : 'Normalizing query and checking recent chat context.'), likelyGateBlocked ? 'skipped' : 'running'), 600));
        circuitTimers.push(window.setTimeout(() => updateCircuitStep('rewrite', likelyGateBlocked ? 'blocked' : 'done', circuitContent(likelyGateBlocked ? 'Skipped by intent gate.' : 'Query ready for retrieval.'), likelyGateBlocked ? 'skipped' : 'done'), 1100));
        circuitTimers.push(window.setTimeout(() => {
            if (likelyGateBlocked) {
                updateCircuitStep('vector', 'blocked', circuitContent('Skipped because this is not a document question.'), 'skipped');
                updateCircuitStep('keyword', 'blocked', circuitContent('Skipped because this is not a document question.'), 'skipped');
                updateCircuitStep('metadata', 'blocked', circuitContent('Skipped because this is not a document question.'), 'skipped');
                updateCircuitStep('merge', 'blocked', circuitContent('No retrieved candidates to rerank.'), 'skipped');
                updateCircuitStep('evidence', 'blocked', circuitContent('No context window was built.'), 'none');
                updateCircuitStep('llm', 'done', circuitContent('Direct safe response without document retrieval.'), 'direct');
                updateCircuitStep('citations', 'blocked', 'No citation because no document evidence was used.', 'none');
                return;
            }
            updateCircuitStep('vector', 'running', circuitContent('Embedding question and searching ChromaDB.'), 'running');
            updateCircuitStep('keyword', 'running', circuitContent('Scanning exact terms and chapter words.'), 'running');
            updateCircuitStep('metadata', 'running', circuitContent('Checking file, chapter, variant and duplicate metadata.'), 'running');
        }, 1300));
        if (!likelyGateBlocked) {
            circuitTimers.push(window.setTimeout(() => updateCircuitStep('merge', 'running', circuitContent('Reranking retrieved candidates with RRF/scoring.'), 'running'), 2100));
            circuitTimers.push(window.setTimeout(() => updateCircuitStep('evidence', 'running', circuitContent('Building the context window from selected chunks.'), 'running'), 2500));
            circuitTimers.push(window.setTimeout(() => updateCircuitStep('llm', 'running', circuitContent('Local model is preparing an answer from selected context.'), 'running'), 3400));
        }
    }

    function renderEvidenceMini(contexts) {
        const items = (contexts || []).slice(0, 3).map(ctx => {
            const parts = [ctx.source || 'source'];
            const chapter = readTraceValue(ctx, 'chapterNumber', 'chapter_number');
            const page = readTraceValue(ctx, 'pageNumber', 'page_number');
            const section = readTraceValue(ctx, 'sectionPath', 'section_path');
            const score = readTraceValue(ctx, 'similarity');
            if (chapter) parts.push(`chapter ${chapter}`);
            if (page) parts.push(`page ${page}`);
            if (section) parts.push(compactText(section, 35));
            if (typeof score === 'number' && score > 0) parts.push(`score ${score.toFixed(2)}`);
            const preview = readTraceValue(ctx, 'content', 'preview');
            return `<div class="evidence-item">
                <strong>${escapeHtml(parts.join(' · '))}</strong>
                <span>${escapeHtml(compactText(preview, 135))}</span>
            </div>`;
        }).join('');
        return items ? `<div class="evidence-mini">${items}</div>` : '';
    }

    function renderBranchPreview(branch) {
        const previews = asArray(branch?.top_preview || branch?.topPreview);
        if (!previews.length) return '';
        return `<div class="circuit-detail">${previews.slice(0, 2).map(item => {
            const bits = [item.source || 'source'];
            const chapter = readTraceValue(item, 'chapterNumber', 'chapter_number');
            const page = readTraceValue(item, 'pageNumber', 'page_number');
            const score = readTraceValue(item, 'score');
            if (chapter) bits.push(`chapter ${chapter}`);
            if (page) bits.push(`page ${page}`);
            if (typeof score === 'number' && score > 0) bits.push(`score ${score.toFixed(2)}`);
            return `<span class="trace-line"><strong>${escapeHtml(compactText(bits.join(' · '), 80))}</strong> ${escapeHtml(compactText(item.preview || '', 95))}</span>`;
        }).join('')}</div>`;
    }

    function getTraceRounds(processing, trace) {
        const retrieval = processing?.retrieval || {};
        const agentic = processing?.agentic_trace || processing?.agenticTrace || trace?.agentic_trace || trace?.agenticTrace || {};
        const rounds = asArray(retrieval.rounds).length ? retrieval.rounds : asArray(agentic.rounds);
        if (rounds.length) return rounds;
        if (retrieval.branches || retrieval.merge) {
            return [{
                round: 1,
                query: (processing?.query || {}).rewritten || (processing?.query || {}).original || latestCircuitQuestion,
                branches: retrieval.branches || {},
                merge: retrieval.merge || {}
            }];
        }
        return [];
    }

    function renderTraceMetric(label, value) {
        return `<div class="trace-metric"><span>${escapeHtml(label)}</span><strong>${escapeHtml(value === undefined || value === null || value === '' ? '-' : String(value))}</strong></div>`;
    }

    function branchCount(branch) {
        return Number(branch?.candidate_count ?? branch?.candidateCount ?? 0);
    }

    function branchDuration(branch) {
        const duration = Number(branch?.duration_ms ?? branch?.durationMs ?? 0);
        return duration ? `${duration} ms` : 'cached/instant';
    }

    function renderTraceBranch(name, branch) {
        const count = branchCount(branch);
        const previews = asArray(branch?.top_preview || branch?.topPreview);
        const preview = previews[0]
            ? compactText(`${previews[0].source || 'source'} ${previews[0].preview || ''}`, 120)
            : (count ? 'Candidates found.' : 'No candidates in this branch.');
        return `<div class="trace-branch">
            <strong>${escapeHtml(name)} <em>${count}</em></strong>
            <span>${escapeHtml(branchDuration(branch))}</span>
            <span>${escapeHtml(preview)}</span>
        </div>`;
    }

    function renderTraceRounds(rounds, retrieval) {
        if (!rounds.length) {
            return `<div class="trace-loop">
                <div class="trace-loop-head"><span>Retrieval skipped</span><span>${escapeHtml(retrieval?.strategy || 'no retrieval')}</span></div>
                <div class="trace-loop-note">No document search was needed for this intent.</div>
                <div class="trace-branches">
                    ${renderTraceBranch('Vector', {})}
                    ${renderTraceBranch('Keyword', {})}
                    ${renderTraceBranch('Metadata', {})}
                </div>
            </div>`;
        }

        return rounds.map((round, index) => {
            const branches = round.branches || {};
            const merge = round.merge || {};
            const query = round.query || round.planned_query || round.rewritten || '';
            const selected = merge.selected_count ?? merge.selectedCount ?? round.selected_count ?? retrieval?.selected_count ?? 0;
            const merged = merge.candidate_count ?? merge.candidateCount ?? round.candidate_count ?? retrieval?.candidate_count ?? 0;
            return `<div class="trace-loop">
                <div class="trace-loop-head">
                    <span>Round ${escapeHtml(round.round || index + 1)}${query ? ` · ${escapeHtml(compactText(query, 72))}` : ''}</span>
                    <span>${escapeHtml(merged)} merged · ${escapeHtml(selected)} selected</span>
                </div>
                <div class="trace-loop-note">Retriever runs these three branches in parallel. RRF/scoring reranks the combined candidates before context selection.</div>
                <div class="trace-loop-path">
                    <span>Parallel search branches</span>
                    <i class="bi bi-arrow-right"></i>
                    <span>Merge by RRF/scoring</span>
                </div>
                <div class="trace-branches">
                    ${renderTraceBranch('Vector', branches.vector || {})}
                    ${renderTraceBranch('Keyword', branches.keyword || {})}
                    ${renderTraceBranch('Metadata', branches.metadata || {})}
                </div>
                <div class="trace-merge-note">
                    <span><strong>Retrieved:</strong> ${escapeHtml(merged)} candidates</span>
                    <span><strong>Reranked/selected:</strong> ${escapeHtml(selected)} chunks</span>
                    <span><strong>Ranker:</strong> ${escapeHtml(merge.strategy || retrieval?.strategy || 'hybrid + RRF')}</span>
                </div>
            </div>`;
        }).join('');
    }

    function renderTraceEvidenceDetail(contexts) {
        if (!contexts.length) return '<div class="empty-hint"><i class="bi bi-shield-slash"></i>No selected evidence for this answer.</div>';
        return `<div class="trace-evidence-list">${contexts.map(ctx => {
            const parts = [ctx.source || 'source'];
            const chapter = readTraceValue(ctx, 'chapterNumber', 'chapter_number');
            const page = readTraceValue(ctx, 'pageNumber', 'page_number');
            const section = readTraceValue(ctx, 'sectionPath', 'section_path');
            const score = readTraceValue(ctx, 'similarity');
            if (chapter) parts.push(`chapter ${chapter}`);
            if (page) parts.push(`page ${page}`);
            if (section) parts.push(compactText(section, 58));
            if (typeof score === 'number' && score > 0) parts.push(`score ${score.toFixed(2)}`);
            const preview = readTraceValue(ctx, 'content', 'preview');
            return `<div class="evidence-item">
                <strong>${escapeHtml(parts.join(' · '))}</strong>
                <span>${escapeHtml(compactText(preview, 260))}</span>
            </div>`;
        }).join('')}</div>`;
    }

    function buildCircuitTraceHtml(trace, sourceDocuments) {
        const processing = getProcessingTrace(trace) || {};
        const retrieval = processing.retrieval || {};
        const query = processing.query || {};
        const scope = processing.scope || {};
        const checker = processing.checker || {};
        const llm = processing.llm || {};
        const contexts = traceEvidenceItems(processing, trace);
        const rounds = getTraceRounds(processing, trace);
        const sources = Array.from(contexts.length ? sourceNamesFromEvidence(contexts) : new Set([...splitSources(sourceDocuments), ...asArray(processing.citations)])).filter(Boolean);
        const confidence = typeof checker.confidence === 'number'
            ? checker.confidence
            : (typeof trace?.confidence === 'number' ? trace.confidence : 0);

        const retrievalSkipped = !rounds.length;
        return `<div class="trace-dashboard">
            <div class="trace-map-title">
                <div>
                    <h4><i class="bi bi-motherboard"></i> System map for this answer</h4>
                    <p>This view shows what the system used, which branches ran, which evidence entered context, and whether citations were attached.</p>
                </div>
                <span class="trace-stage-status">${retrievalSkipped ? 'guarded path' : 'rag path'}</span>
            </div>
            <div class="trace-legend">
                <span><i class="ok"></i> Done: step finished</span>
                <span><i class="run"></i> Retriever: Vector, Keyword, Metadata run together</span>
                <span><i class="skip"></i> Skipped/blocked: no trusted evidence used</span>
            </div>
            <div class="trace-section-label">Document indexing reference</div>
            <div class="trace-mini-flow">
                <div class="trace-mini-step"><strong>Upload</strong><span>Lecturer adds PDF, DOCX, PPT, or PPTX into a subject workspace.</span></div>
                <div class="trace-mini-step"><strong>Extract</strong><span>AI Service extracts text and keeps document, page, and subject metadata.</span></div>
                <div class="trace-mini-step"><strong>Chunk</strong><span>Text is split by chapter/section-aware chunks with overlap.</span></div>
                <div class="trace-mini-step"><strong>Embed</strong><span>Qwen embedding turns each chunk into a 1024-dimensional vector.</span></div>
                <div class="trace-mini-step"><strong>Store</strong><span>SQL stores app metadata; ChromaDB stores chunk text, vector, and retrieval metadata.</span></div>
            </div>
            <div class="trace-section-label">Runtime trace for this question</div>
            <div class="trace-flow">
                <section class="trace-stage" data-step="01">
                    <div class="trace-stage-head">
                        <div class="trace-stage-title"><i class="bi bi-chat-dots"></i><div>Intent gate and scope<small>Decides whether this is a document-learning question before touching ChromaDB.</small></div></div>
                        <span class="trace-stage-status">${escapeHtml(scope.decision || 'checked')}</span>
                    </div>
                    <div class="trace-metrics">
                        ${renderTraceMetric('Intent', processing.intent || 'document_question')}
                        ${renderTraceMetric('Subject', scope.subject_id || currentSubjectId)}
                        ${renderTraceMetric('Collection', scope.collection || 'edu_documents')}
                        ${renderTraceMetric('Document filter', asArray(scope.document_filter || scope.document_ids).join(' | ') || 'all indexed docs')}
                    </div>
                </section>
                <section class="trace-stage" data-step="02">
                    <div class="trace-stage-head">
                        <div class="trace-stage-title"><i class="bi bi-pencil-square"></i><div>Rewrite and memory<small>Turns follow-ups into standalone retrieval queries and preserves topic scope.</small></div></div>
                        <span class="trace-stage-status">${escapeHtml(query.rewritten ? 'rewritten' : 'ready')}</span>
                    </div>
                    <div class="trace-metrics">
                        ${renderTraceMetric('Original question', compactText(query.original || latestCircuitQuestion, 120))}
                        ${renderTraceMetric('Rewritten query', compactText(query.rewritten || query.original || latestCircuitQuestion, 120))}
                        ${renderTraceMetric('History used', yesNo(query.history_used))}
                        ${renderTraceMetric('Subject memory used', yesNo(query.subject_memory_used))}
                    </div>
                </section>
                <section class="trace-stage" data-step="03">
                    <div class="trace-stage-head">
                        <div class="trace-stage-title"><i class="bi bi-search"></i><div>Parallel retrieval loop<small>Each round runs vector, keyword, and metadata search, then merges candidates.</small></div></div>
                        <span class="trace-stage-status ${retrievalSkipped ? 'skip' : ''}">${retrievalSkipped ? 'skipped' : `${rounds.length} round${rounds.length === 1 ? '' : 's'}`}</span>
                    </div>
                    ${renderTraceRounds(rounds, retrieval)}
                </section>
                <section class="trace-stage" data-step="04">
                    <div class="trace-stage-head">
                        <div class="trace-stage-title"><i class="bi bi-filter-square"></i><div>Rerank and context window<small>RRF/scoring ranks retrieved chunks; only selected chunks enter the LLM context.</small></div></div>
                        <span class="trace-stage-status ${contexts.length ? '' : 'skip'}">${contexts.length ? `${contexts.length} chunks` : 'none'}</span>
                    </div>
                    <div class="trace-loop-note">Current demo uses RRF/scoring for reranking. A heavier cross-encoder reranker can be enabled later, but it is not on by default for this 4GB VRAM setup.</div>
                    ${renderTraceEvidenceDetail(contexts)}
                </section>
                <section class="trace-stage" data-step="05">
                    <div class="trace-stage-head">
                        <div class="trace-stage-title"><i class="bi bi-stars"></i><div>Local LLM answer<small>The model receives selected evidence only, then the UI attaches citations.</small></div></div>
                        <span class="trace-stage-status">${escapeHtml(llm.model || trace?.model || 'local')}</span>
                    </div>
                    <div class="trace-metrics">
                        ${renderTraceMetric('Model', llm.model || trace?.model || 'local model')}
                        ${renderTraceMetric('Policy', llm.policy || 'answer from selected evidence')}
                        ${renderTraceMetric('Confidence', confidence ? confidence.toFixed(2) : '-')}
                        ${renderTraceMetric('Fallback used', yesNo(llm.fallback_used || trace?.fallbackUsed || trace?.fallback_used))}
                    </div>
                </section>
                <section class="trace-stage" data-step="06">
                    <div class="trace-stage-head">
                        <div class="trace-stage-title"><i class="bi bi-link-45deg"></i><div>Citations<small>Only sources tied to selected evidence are shown to the user.</small></div></div>
                        <span class="trace-stage-status ${sources.length ? '' : 'skip'}">${sources.length ? `${sources.length} source${sources.length === 1 ? '' : 's'}` : 'none'}</span>
                    </div>
                    ${sources.length
                        ? `<div class="trace-metrics">${sources.map((source, index) => renderTraceMetric(`Source ${index + 1}`, source)).join('')}</div>`
                        : '<div class="empty-hint"><i class="bi bi-link-45deg"></i>No citation attached because no trusted document evidence was used.</div>'}
                </section>
            </div>
        </div>`;
    }

    function openCircuitTraceModal() {
        if (!circuitTraceModal || !circuitTraceBody) return;
        circuitTraceModal.classList.add('show');
        circuitTraceModal.setAttribute('aria-hidden', 'false');
        if (!latestCircuitTrace) {
            circuitTraceSubtitle.textContent = 'Ask a question to inspect retrieval rounds, evidence, model, and citations.';
            circuitTraceBody.innerHTML = '<div class="empty-hint"><i class="bi bi-cpu"></i>No trace yet. Send a question first.</div>';
            return;
        }
        circuitTraceSubtitle.textContent = latestCircuitQuestion
            ? `Question: ${compactText(latestCircuitQuestion, 130)}`
            : 'Trace from the latest AI response.';
        circuitTraceBody.innerHTML = buildCircuitTraceHtml(latestCircuitTrace, latestCircuitSources);
    }

    function closeCircuitTraceModal() {
        if (!circuitTraceModal) return;
        circuitTraceModal.classList.remove('show');
        circuitTraceModal.setAttribute('aria-hidden', 'true');
    }

    function updateBranchStep(step, branch, skipped) {
        if (skipped) {
            updateCircuitStep(step, 'blocked', circuitContent('Skipped for this intent.'), 'skipped');
            return;
        }

        const status = branch?.status === 'error' ? 'error' : 'done';
        const count = Number(branch?.candidate_count ?? branch?.candidateCount ?? 0);
        const duration = Number(branch?.duration_ms ?? branch?.durationMs ?? 0);
        const label = step === 'vector'
            ? 'Semantic matches from ChromaDB.'
            : step === 'keyword'
                ? 'Exact word and BM25 matches.'
                : 'Document, chapter and variant hints.';
        const detail = renderBranchPreview(branch);
        updateCircuitStep(
            step,
            count > 0 ? status : 'blocked',
            circuitContent(label, detail, [`${count} candidates`, duration ? `${duration} ms` : 'cached/instant']),
            count > 0 ? 'done' : 'none'
        );
    }

    function finishCircuit(trace, sourceDocuments) {
        clearCircuitTimers();
        latestCircuitTrace = trace || {};
        latestCircuitSources = sourceDocuments || '';
        const processing = getProcessingTrace(trace) || {};
        const intent = processing.intent || 'document_question';
        const scope = processing.scope || {};
        const query = processing.query || {};
        const retrieval = processing.retrieval || {};
        const branches = retrieval.branches || {};
        const merge = retrieval.merge || {};
        const checker = processing.checker || {};
        const llm = processing.llm || {};
        const contexts = traceEvidenceItems(processing, trace);
        const sourceSet = contexts.length ? sourceNamesFromEvidence(contexts) : new Set([...splitSources(sourceDocuments), ...asArray(processing.citations)]);
        const sources = Array.from(sourceSet).filter(Boolean);
        const confidence = typeof checker.confidence === 'number'
            ? checker.confidence
            : (typeof trace?.confidence === 'number' ? trace.confidence : 0);
        const model = llm.model || trace?.model || 'local model';
        const strategy = retrieval.strategy || trace?.retrievalStrategy || trace?.retrieval_strategy || 'hybrid retrieval';
        const blockedIntent = ['out_of_scope', 'non_document_question', 'low_confidence', 'ambiguous_acronym'].includes(intent);
        const skippedIntent = ['greeting', 'small_talk', 'arithmetic', 'system'].includes(intent);
        const rounds = getTraceRounds(processing, trace);
        setCircuitSummary(intent, Math.max(1, rounds.length || (skippedIntent || blockedIntent ? 0 : 1)), contexts.length);

        const scopeHtml = [
            traceLine('intent', intent),
            traceLine('subject', scope.subject_id),
            traceLine('decision', scope.decision),
            traceList('doc filter', scope.document_filter || scope.document_ids, 2)
        ].join('');

        const rewriteHtml = [
            traceLine('original', compactText(query.original || '', 90)),
            traceLine('rewritten', compactText(query.rewritten || query.original || '', 110)),
            traceLine('history', yesNo(query.history_used)),
            traceLine('memory', yesNo(query.subject_memory_used))
        ].join('');

        const retrievalHtml = skippedIntent || blockedIntent
            ? traceLine('action', scope.decision || 'retrieval skipped')
            : [
                traceLine('collection', scope.collection || 'edu_documents'),
                traceLine('strategy', strategy),
                traceList('planned', retrieval.planned_queries, 2),
                traceLine('candidates', retrieval.candidate_count ?? 0),
                traceLine('selected', retrieval.selected_count ?? contexts.length)
            ].join('');

        const mergeHtml = skippedIntent || blockedIntent
            ? traceLine('action', scope.decision || 'merge skipped')
            : [
                traceLine('strategy', merge.strategy || 'reciprocal_rank_fusion'),
                traceLine('merged', merge.candidate_count ?? retrieval.candidate_count ?? 0),
                traceLine('selected', merge.selected_count ?? retrieval.selected_count ?? contexts.length)
            ].join('');

        const evidenceHtml = contexts.length
            ? `${traceLine('selected chunks', contexts.length)}${renderEvidenceMini(contexts)}`
            : traceLine('evidence', blockedIntent ? 'blocked because evidence is weak or out of scope' : 'no document chunks used');

        const llmHtml = [
            traceLine('model', model),
            traceLine('policy', llm.policy || (skippedIntent ? 'direct safe response' : 'document-grounded answer')),
            traceLine('fallback', yesNo(llm.fallback_used || trace?.fallbackUsed || trace?.fallback_used)),
            confidence ? traceLine('confidence', confidence.toFixed(2)) : ''
        ].join('');

        updateCircuitStep('scope', blockedIntent ? 'blocked' : 'done', circuitContent('Scope decision completed.', scopeHtml), blockedIntent ? 'blocked' : 'checked');
        updateCircuitStep('rewrite', skippedIntent ? 'blocked' : 'done', circuitContent('Query prepared.', rewriteHtml), skippedIntent ? 'skipped' : 'done');
        updateBranchStep('vector', branches.vector, skippedIntent || blockedIntent);
        updateBranchStep('keyword', branches.keyword, skippedIntent || blockedIntent);
        updateBranchStep('metadata', branches.metadata, skippedIntent || blockedIntent);
        updateCircuitStep('merge', skippedIntent || blockedIntent ? 'blocked' : 'done', circuitContent('Retrieved candidates reranked.', mergeHtml), skippedIntent ? 'skipped' : (blockedIntent ? 'blocked' : 'done'));
        updateCircuitStep('evidence', contexts.length ? 'done' : 'blocked', evidenceHtml, contexts.length ? 'done' : 'none');
        updateCircuitStep('llm', blockedIntent && !sources.length ? 'blocked' : 'done', circuitContent(skippedIntent ? 'Direct safe response.' : 'Answer step completed.', llmHtml), skippedIntent ? 'direct' : 'done');
        updateCircuitStep('citations', sources.length ? 'done' : 'blocked',
            sources.length ? circuitContent(`${sources.length} source${sources.length > 1 ? 's' : ''} attached.`, traceList('sources', sources, 4)) : 'No citation because no document evidence was used.',
            sources.length ? 'done' : 'none');
        setCircuitState('Complete');
    }

    function stopCircuit() {
        clearCircuitTimers();
        setCircuitState('Stopped');
        setCircuitSummary('stopped', 0, 0);
        updateCircuitStep('llm', 'blocked', 'Request stopped by user before completion.', 'stopped');
    }

    function failCircuit(message) {
        clearCircuitTimers();
        setCircuitState('Error');
        setCircuitSummary('error', 0, 0);
        updateCircuitStep('evidence', 'error', escapeHtml(message || 'AI request failed.'), 'error');
        updateCircuitStep('llm', 'error', 'No final answer was generated.', 'error');
    }

    if (chatForm) {
        sendBtn.addEventListener('click', function (event) {
            if (!activeChatController) return;
            event.preventDefault();
            activeChatController.abort();
        });

        chatForm.addEventListener('submit', function (event) {
            event.preventDefault();
            if (activeChatController) return;

            if (!aiReady) {
                setAiStatus('starting', 'AI chua san sang');
                checkAiStatus();
                return;
            }

            if (!hasIndexedDocs || uploadInProgress) {
                const waitingText = uploadInProgress
                    ? 'A document is still being read, chunked, and embedded. Wait until the progress bar finishes, then ask again.'
                    : 'This subject has no indexed documents yet. Upload a document before asking content questions.';
                const loadingNode = appendBotLoading();
                setBotMessage(loadingNode, waitingText, '');
                failCircuit(waitingText);
                return;
            }

            const message = chatInput.value.trim();
            if (!message) return;

            const formData = new FormData(chatForm);
            appendUserMessage(message);
            chatInput.value = '';
            setSending(true);
            startCircuit(message);
            const loadingNode = appendBotLoading();
            activeChatController = new AbortController();

            fetch(chatForm.action, {
                method: 'POST',
                body: formData,
                signal: activeChatController.signal,
                headers: {
                    'X-Requested-With': 'XMLHttpRequest',
                    'Accept': 'application/json',
                    'RequestVerificationToken': requestToken(chatForm)
                }
            })
                .then(async response => {
                    const data = await response.json().catch(() => ({}));
                    if (!response.ok || !data.success) {
                        throw new Error(data.message || 'Khong nhan duoc phan hoi tu AI.');
                    }
                    setBotMessage(loadingNode, data.bot.content, data.bot.sourceDocuments, data.trace);
                    finishCircuit(data.trace, data.bot.sourceDocuments);
                })
                .catch(error => {
                    if (error.name === 'AbortError') {
                        loadingNode.remove();
                        stopCircuit();
                        return;
                    }
                    setBotMessage(loadingNode, error.message || 'Loi ket noi toi AI Engine.', '');
                    failCircuit(error.message);
                })
                .finally(() => {
                    activeChatController = null;
                    setSending(false);
                    chatInput.focus();
                });
        });
    }

    const uploadFile = document.getElementById('uploadFile');
    const uploadForm = document.getElementById('uploadForm');
    const uploadProgress = document.getElementById('uploadProgress');
    const progressFile = document.getElementById('progressFile');
    const progressPercent = document.getElementById('progressPercent');
    const progressFill = document.getElementById('progressFill');
    const progressNote = document.getElementById('progressNote');

    function setUploadProgress(percent, note) {
        const safePercent = Math.max(0, Math.min(100, Math.round(percent)));
        progressPercent.textContent = safePercent + '%';
        progressFill.style.width = safePercent + '%';
        progressNote.textContent = note;
    }

    if (uploadFile && uploadForm) {
        uploadFile.addEventListener('change', function () {
            if (!uploadFile.files || uploadFile.files.length === 0) return;

            const file = uploadFile.files[0];
            const formData = new FormData(uploadForm);
            const xhr = new XMLHttpRequest();
            let processingTimer = null;
            let processingStartedAt = 0;

            uploadProgress.classList.add('show');
            uploadInProgress = true;
            setChatAvailability(aiReady);
            progressFill.style.background = 'linear-gradient(90deg, #667eea, #81c995)';
            progressFile.textContent = file.name;
            setUploadProgress(0, 'Sending file to server.');

            xhr.upload.onprogress = function (event) {
                if (!event.lengthComputable) return;
                const uploadPercent = (event.loaded / event.total) * 70;
                setUploadProgress(uploadPercent, 'Uploading file...');
            };

            xhr.onloadstart = function () {
                setUploadProgress(2, 'Preparing upload...');
            };

            xhr.upload.onload = function () {
                processingStartedAt = Date.now();
                setUploadProgress(72, 'Upload complete. Server is reading, chunking, and embedding the document. Large PDFs can take a few minutes.');
                if (!processingTimer) {
                    processingTimer = window.setInterval(function () {
                        const elapsedSeconds = Math.floor((Date.now() - processingStartedAt) / 1000);
                        const estimatedPercent = Math.min(90, 72 + Math.floor(elapsedSeconds / 8));
                        setUploadProgress(estimatedPercent, 'Embedding on the AI Engine. For long PDFs, wait until completion is reported.');
                    }, 2000);
                }
            };

            xhr.onload = function () {
                if (processingTimer) window.clearInterval(processingTimer);

                let result = {};
                try {
                    result = JSON.parse(xhr.responseText || '{}');
                } catch {
                    result = { message: 'Could not read the server response.' };
                }

                if (xhr.status >= 200 && xhr.status < 300 && result.indexed) {
                    hasIndexedDocs = true;
                    uploadInProgress = false;
                    setChatAvailability(aiReady);
                    setUploadProgress(100, `Completed: ${result.chunks || 0} content chunks indexed.`);
                    window.setTimeout(function () {
                        window.location.href = result.returnUrl || window.location.href;
                    }, 900);
                } else {
                    uploadInProgress = false;
                    setChatAvailability(aiReady);
                    progressFill.style.background = '#ea4335';
                    setUploadProgress(100, result.message || 'Indexing failed. Check the Python AI Service.');
                }
            };

            xhr.onerror = function () {
                if (processingTimer) window.clearInterval(processingTimer);
                uploadInProgress = false;
                setChatAvailability(aiReady);
                progressFill.style.background = '#ea4335';
                setUploadProgress(100, 'Could not connect to the server while uploading.');
            };

            xhr.open('POST', uploadForm.action);
            xhr.setRequestHeader('X-Requested-With', 'XMLHttpRequest');
            xhr.setRequestHeader('Accept', 'application/json');
            xhr.setRequestHeader('RequestVerificationToken', requestToken(uploadForm));
            xhr.send(formData);
        });
    }
    
    // Confirm destructive document and chat actions with SweetAlert2.
    async function openChunkInspector(documentId, fileName) {
        const modal = document.getElementById('chunkInspector');
        const body = document.getElementById('inspectorBody');
        document.getElementById('inspectorFileName').textContent = fileName || `Document #${documentId}`;
        modal.classList.add('show');
        modal.setAttribute('aria-hidden', 'false');
        body.innerHTML = '<div class="text-center text-secondary py-4"><span class="spinner-border spinner-border-sm me-2"></span>Loading chunks...</div>';

        try {
            const response = await fetch(`?handler=DocumentChunks&documentId=${documentId}&offset=0&limit=5`, { headers: { 'Accept': 'application/json' } });
            const data = await response.json();
            if (!response.ok) throw new Error(data.message || 'Cannot load chunks.');
            body.innerHTML = renderChunkInspector(data);
        } catch (error) {
            body.innerHTML = `<div class="inspect-panel text-danger">${escapeHtml(error.message || 'Cannot load chunks.')}</div>`;
        }
    }

    function closeChunkInspector() {
        const modal = document.getElementById('chunkInspector');
        modal.classList.remove('show');
        modal.setAttribute('aria-hidden', 'true');
    }

    document.addEventListener('click', function (event) {
        const button = event.target.closest('[data-inspect-document-id]');
        if (!button) return;

        event.preventDefault();
        event.stopPropagation();
        openChunkInspector(button.dataset.inspectDocumentId, button.dataset.inspectFileName || '');
    });

    window.openChunkInspector = openChunkInspector;
    window.closeChunkInspector = closeChunkInspector;

    function renderChunkInspector(data) {
        const firstChunk = (data.chunks || [])[0] || {};
        const meta = firstChunk.metadata || {};
        const embeddingModel = data.embeddingModel || data.embedding_model || meta.embeddingModel || meta.embedding_model || 'Qwen/Qwen3-Embedding-0.6B';
        const dimensions = firstChunk.embeddingDimensions || firstChunk.embedding_dimensions || 0;
        const subjectScope = meta.subjectId ?? meta.subject_id ?? '-';
        const documentId = data.documentId || data.document_id || meta.documentId || meta.document_id || '';
        const chunks = (data.chunks || []).map(chunk => {
            const preview = (chunk.embeddingPreview || []).slice(0, 12)
                .map(v => `<span class="vector-pill">${Number(v).toFixed(4)}</span>`)
                .join('');
            const chunkMeta = chunk.metadata || {};
            const page = chunkMeta.pageNumber ?? chunkMeta.page_number;
            const chapter = chunkMeta.chapterNumber ?? chunkMeta.chapter_number;
            const section = chunkMeta.sectionTitle ?? chunkMeta.section_title ?? chunkMeta.sectionPath ?? chunkMeta.section_path;
            const metaLine = [
                `chunk #${chunkMeta.chunkIndex ?? chunkMeta.chunk_index ?? 0}`,
                `${chunkMeta.chunkLength ?? chunkMeta.chunk_length ?? 0} chars`,
                `${chunk.embeddingDimensions || chunk.embedding_dimensions || 0} dims`,
                page ? `page ${page}` : '',
                chapter ? `chapter ${chapter}` : '',
                section ? escapeHtml(section) : ''
            ].filter(Boolean).join(' · ');
            return `<div class="chunk-card">
                <div class="chunk-head"><span>${escapeHtml(chunk.id)}</span><span>${metaLine}</span></div>
                <div class="chunk-text">${escapeHtml(chunk.text || '')}</div>
                <div class="vector-preview">${preview}</div>
            </div>`;
        }).join('');

        return `<div class="pipeline-board">
            <div class="pipeline-phase">
                <h4><i class="bi bi-upload"></i> 1. When a lecturer uploads this document</h4>
                <div class="pipeline-strip">
                    <div class="flow-chip"><span>01</span>Extract text</div>
                    <div class="flow-arrow">→</div>
                    <div class="flow-chip"><span>02</span>Chunk by section/page</div>
                    <div class="flow-arrow">→</div>
                    <div class="flow-chip"><span>03</span>Embed with ${escapeHtml(embeddingModel)}</div>
                    <div class="flow-arrow">→</div>
                    <div class="flow-chip"><span>04</span>Store SQL + ChromaDB</div>
                </div>
            </div>
            <div class="pipeline-phase">
                <h4><i class="bi bi-chat-square-text"></i> 2. When a student asks a question</h4>
                <div class="pipeline-strip answer-flow">
                    <div class="flow-chip"><span>Query</span>Rewrite/check</div>
                    <div class="flow-arrow">→</div>
                    <div class="flow-chip"><span>Search</span>Vector + keyword</div>
                    <div class="flow-arrow">→</div>
                    <div class="flow-chip"><span>Evidence</span>Pick chunks</div>
                    <div class="flow-arrow">→</div>
                    <div class="flow-chip"><span>LLM</span>Answer from context</div>
                    <div class="flow-arrow">→</div>
                    <div class="flow-chip"><span>Cite</span>Show sources</div>
                </div>
                <div class="pipeline-note">The real stored evidence is shown below. Vector preview only shows the first values.</div>
            </div>
        </div>
        <div class="inspect-grid">
            <div>
                <div class="inspect-panel">
                    <h4>Actual index metadata</h4>
                    <div class="inspect-kv">
                        <span>Status</span><strong>Indexed</strong>
                        <span>Collection</span><strong>edu_documents</strong>
                        <span>Embedding model</span><strong>${escapeHtml(embeddingModel)}</strong>
                        <span>Vector dimensions</span><strong>${dimensions || 'unknown'}</strong>
                        <span>Chunk config</span><strong>size = 850, overlap = 120</strong>
                        <span>Subject scope</span><strong>subject_id = ${subjectScope}</strong>
                        <span>Document metadata</span><strong>document_id = ${escapeHtml(documentId)}</strong>
                        <span>Total chunks</span><strong>${data.total || 0}</strong>
                        <span>Showing</span><strong>${(data.offset || 0) + 1}-${(data.offset || 0) + (data.chunks?.length || 0)}</strong>
                    </div>
                </div>
                <div class="storage-grid">
                    <div class="storage-card"><strong><i class="bi bi-database"></i> SQL Server</strong>File name, subject, owner, index status, chunk count, chat sessions, and audit events.</div>
                    <div class="storage-card"><strong><i class="bi bi-hdd-network"></i> ChromaDB</strong>Chunk text, embedding vector, source metadata, and retrieval scope.</div>
                </div>
            </div>
            <div class="inspect-panel">
                <h4>Stored chunks and vector preview</h4>
                <div class="chunk-list">${chunks || '<div class="text-secondary">No chunks returned from AI service.</div>'}</div>
            </div>
        </div>`;
    }

    function confirmDelete(e, form) {
        e.preventDefault();
        Swal.fire({
            title: 'Delete this document?',
            text: "The bot will no longer answer from this document.",
            icon: 'warning',
            showCancelButton: true,
            confirmButtonColor: '#ea4335',
            cancelButtonColor: '#2a2a2e',
            confirmButtonText: '<i class="bi bi-trash3"></i> Delete',
            cancelButtonText: 'Cancel',
            background: '#1a1a1e',
            color: '#e8eaed'
        }).then((result) => {
            if (result.isConfirmed) {
                form.submit();
            }
        });
        return false;
    }

    function confirmDeleteSession(e, form) {
        e.preventDefault();
        Swal.fire({
            title: 'Delete this chat?',
            text: 'All messages in this chat session will be deleted.',
            icon: 'warning',
            showCancelButton: true,
            confirmButtonColor: '#ea4335',
            cancelButtonColor: '#2a2a2e',
            confirmButtonText: '<i class="bi bi-trash3"></i> Delete',
            cancelButtonText: 'Cancel',
            background: '#1a1a1e',
            color: '#e8eaed'
        }).then((result) => {
            if (result.isConfirmed) {
                form.submit();
            }
        });
        return false;
    }
</script>
